using System;
using System.Collections.Generic;
using System.Drawing;
using System.Linq;
using System.IO;
using System.Speech.Synthesis;
using System.Windows.Forms;
using WordQuest.BUS;
using WordQuest.DTO;

namespace WordQuest.GUI
{
    public partial class frmGame : Form
    {
        #region ==================== Constants ====================

        private const int SLOT_WIDTH = 45;
        private const int SLOT_HEIGHT = 50;
        private const int LETTER_BTN_WIDTH = 55;
        private const int LETTER_BTN_HEIGHT = 55;
        private const int GAP = 6;

        private static readonly Color COLOR_SLOT_DEFAULT = Color.FromArgb(139, 90, 43);
        private static readonly Color COLOR_SLOT_FILLED = Color.FromArgb(50, 45, 100);
        private static readonly Color COLOR_CORRECT = Color.FromArgb(78, 203, 113);
        private static readonly Color COLOR_WRONG = Color.FromArgb(255, 107, 107);
        private static readonly Color COLOR_HINT = Color.FromArgb(255, 193, 7);

        #endregion

        #region ==================== Fields ====================

        // Thông tin game
        private readonly int _playerID;
        private readonly int _topicID;
        private readonly string _topicName;
        private readonly string _topicEmoji;
        private readonly int _levelNum;
        private readonly string _gameMode;
        private readonly int _levelID;

        // BUS Layer - Tất cả logic đã được chuyển vào đây
        private readonly GameBUS _gameBUS;

        // UI Components
        private List<Button> _answerSlots;
        private List<Button> _letterButtons;
        private SpeechSynthesizer _speechSynthesizer;

        // Timer UI (chỉ để refresh, không chứa logic)
        private System.Windows.Forms.Timer _uiRefreshTimer;

        #endregion

        #region ==================== Constructor ====================

        public frmGame(int playerID, string username, int topicID, string topicName, string topicEmoji,
                       int levelNum, string gameMode, int levelID)
        {
            InitializeComponent();

            // Lưu tham số
            _playerID = playerID;
            _topicID = topicID;
            _topicName = topicName;
            _topicEmoji = topicEmoji;
            _levelNum = levelNum;
            _gameMode = gameMode;
            _levelID = levelID;

            // Khởi tạo BUS
            _gameBUS = new GameBUS();
            _answerSlots = new List<Button>();
            _letterButtons = new List<Button>();

            // Đăng ký sự kiện từ BUS
            _gameBUS.OnStateChanged += UpdateUI;
            _gameBUS.OnAnswerCompleted += OnAnswerCompleted;
            _gameBUS.OnTimeOut += OnTimeOut;
            _gameBUS.OnGameEnded += OnGameEnded;
            _gameBUS.OnNextWordRequested += LoadCurrentWord;
            _gameBUS.OnScoreChanged += OnScoreChanged;

            // Thiết lập giao diện
            SetupForm();
        }

        #endregion

        #region ==================== Form Events ====================

        private async void frmGame_Load(object sender, EventArgs e)
        {
            try
            {
                Cursor = Cursors.WaitCursor;

                // Khởi tạo Speech
                InitializeSpeech();

                // Khởi tạo game - TẤT CẢ LOGIC TRONG BUS
                await _gameBUS.InitializeGameAsync(_levelID, _gameMode);

                // Khởi tạo timer UI
                StartUIRefreshTimer();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Lỗi khởi tạo game: {ex.Message}", "Lỗi",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
                Close();
            }
            finally
            {
                Cursor = Cursors.Default;
            }
        }

        private void BtnExit_Click(object sender, EventArgs e)
        {
            if (MessageBox.Show("Bạn có chắc muốn thoát?\nTiến độ sẽ không được lưu!",
                "Thoát game", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                _gameBUS.CancelGame();
                CleanupResources();
                Owner?.Show();
                Close();
            }
        }

        private void BtnHint_Click(object sender, EventArgs e)
        {
            char? hintChar = _gameBUS.UseHint();

            if (hintChar.HasValue)
            {
                // Tìm và highlight ô vừa được gợi ý
                int index = _gameBUS.GetCurrentInput().Count - 1;
                if (index >= 0 && index < _answerSlots.Count)
                {
                    _answerSlots[index].BackColor = COLOR_HINT;
                }

                // Ẩn nút chữ cái tương ứng
                var btn = FindLetterButton(hintChar.Value);
                if (btn != null) btn.Visible = false;
            }
        }

        private void AnswerSlot_Click(object sender, EventArgs e)
        {
            if (sender is Button slot)
            {
                int index = _answerSlots.IndexOf(slot);
                if (index >= 0)
                {
                    _gameBUS.RemoveLettersFrom(index);
                }
            }
        }

        private void LetterButton_Click(object sender, EventArgs e)
        {
            if (sender is Button btn && btn.Visible)
            {
                char letter = btn.Text[0];
                var result = _gameBUS.AddLetter(letter);

                // Ẩn nút nếu thêm thành công
                if (result == AnswerResult.Added || result == AnswerResult.Correct)
                {
                    btn.Visible = false;
                }

                // Phát âm thanh nếu đúng
                if (result == AnswerResult.Correct)
                {
                    PlayCorrectSound();
                    SpeakCurrentWord();
                }
                else if (result == AnswerResult.Wrong)
                {
                    PlayWrongSound();
                }
            }
        }

        #endregion

        #region ==================== BUS Event Handlers ====================

        /// <summary>
        /// Cập nhật toàn bộ giao diện từ State của BUS
        /// </summary>
        private void UpdateUI(GameStateDTO state)
        {
            // Cập nhật thông tin game
            lblTopic.Text = $"{_topicEmoji} {_topicName} - Màn {_levelNum}";
            lblQuestion.Text = $"Câu {state.CurrentWordIndex + 1}/{state.TotalQuestions}";
            lblLives.Text = GetLivesDisplay(state.Lives, state.MaxLives);
            lblStreak.Text = $"🔥 {state.Streak}";
            lblScore.Text = state.Score.ToString();

            // Cập nhật timer
            lblTimer.Text = $"{state.RemainingSeconds}s";
            UpdateTimerColor(state.RemainingSeconds);

            try { pbTime.Value = state.ProgressPercent; } catch { }

            // Cập nhật answer slots
            UpdateAnswerSlots(state.CurrentInput);

            // Cập nhật letter buttons (nếu cần refresh)
            if (state.IsWaitingForNext == false && !state.IsAnswered)
            {
                UpdateLetterButtons(state.AvailableLetters);
            }
        }

        /// <summary>
        /// Xử lý khi trả lời xong
        /// </summary>
        private void OnAnswerCompleted(bool isCorrect, string correctAnswer)
        {
            if (isCorrect)
            {
                HighlightAllSlots(COLOR_CORRECT);
            }
            else
            {
                HighlightAllSlots(COLOR_WRONG);
                ShowCorrectAnswer(correctAnswer);
            }
        }

        /// <summary>
        /// Xử lý khi hết giờ
        /// </summary>
        private void OnTimeOut()
        {
            HighlightAllSlots(COLOR_WRONG);
            ShowCorrectAnswer(_gameBUS.GetCorrectAnswer());
            PlayWrongSound();
        }

        /// <summary>
        /// Xử lý khi game kết thúc
        /// </summary>
        private async void OnGameEnded(GameResultDTO result)
        {
            StopUIRefreshTimer();

            // Lưu kết quả
            await _gameBUS.SaveGameResultAsync(_playerID, _topicID, _levelNum);

            // Hiển thị form kết quả
            var resultForm = new frmWin(
                _playerID, "",
                _topicID, _topicName, _topicEmoji,
                _levelNum, result.Score, result.Stars,
                result.CorrectCount, result.TimeTaken,
                result.TotalQuestions, _gameMode)
            {
                Owner = this.Owner
            };

            resultForm.Show();
            CleanupResources();
            Close();
        }

        /// <summary>
        /// Tải câu hỏi mới
        /// </summary>
        private void LoadCurrentWord()
        {
            var question = _gameBUS.GetCurrentQuestion();
            if (question == null) return;

            // Cập nhật hình ảnh
            RenderWordImage(question.ImagePath, question.EmojiIcon);

            // Reset UI
            lblEnglish.Visible = false;
            ResetAnswerSlots(question.CorrectAnswer.Length);
            RebuildLetterButtons();
        }

        /// <summary>
        /// Xử lý khi điểm thay đổi (hiệu ứng)
        /// </summary>
        private void OnScoreChanged(int newScore, int bonus)
        {
            // Có thể thêm animation ở đây
            if (bonus > 0)
            {
                lblStreak.BackColor = Color.Gold;
                Timer t = new Timer { Interval = 500 };
                t.Tick += (s, e) => { lblStreak.BackColor = Color.Transparent; t.Stop(); t.Dispose(); };
                t.Start();
            }
        }

        #endregion

        #region ==================== UI Building ====================

        private void SetupForm()
        {
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = Color.FromArgb(101, 67, 33);

            pnlHeader.BackColor = Color.FromArgb(75, 45, 15);
            picWord.BackColor = Color.FromArgb(120, 80, 40);
            picWord.SizeMode = PictureBoxSizeMode.Zoom;

            lblStreak.Text = "🔥 0";
            lblScore.Text = "0";
            lblEnglish.Visible = false;

            btnHint.BackColor = Color.FromArgb(247, 201, 72);
            btnHint.FlatStyle = FlatStyle.Flat;
        }

        private void BuildAnswerSlots(int slotCount)
        {
            pnlAnswer.SuspendLayout();
            pnlAnswer.Controls.Clear();
            _answerSlots.Clear();

            int totalWidth = slotCount * (SLOT_WIDTH + GAP);
            int startX = Math.Max(5, (pnlAnswer.Width - totalWidth) / 2);

            for (int i = 0; i < slotCount; i++)
            {
                var slot = new Button
                {
                    Size = new Size(SLOT_WIDTH, SLOT_HEIGHT),
                    Location = new Point(startX + i * (SLOT_WIDTH + GAP), 5),
                    Text = "",
                    Font = new Font("Segoe UI", 14, FontStyle.Bold),
                    ForeColor = Color.White,
                    BackColor = COLOR_SLOT_DEFAULT,
                    FlatStyle = FlatStyle.Flat,
                    Tag = i
                };
                slot.Click += AnswerSlot_Click;

                pnlAnswer.Controls.Add(slot);
                _answerSlots.Add(slot);
            }

            pnlAnswer.ResumeLayout();
        }

        private void BuildLetterButtons(List<char> letters)
        {
            pnlLetters.SuspendLayout();
            pnlLetters.Controls.Clear();
            _letterButtons.Clear();

            int totalWidth = letters.Count * (LETTER_BTN_WIDTH + GAP);
            int startX = Math.Max(5, (pnlLetters.Width - totalWidth) / 2);

            for (int i = 0; i < letters.Count; i++)
            {
                var btn = new Button
                {
                    Size = new Size(LETTER_BTN_WIDTH, LETTER_BTN_HEIGHT),
                    Location = new Point(startX + i * (LETTER_BTN_WIDTH + GAP), 5),
                    Text = letters[i].ToString(),
                    Font = new Font("Segoe UI", 16, FontStyle.Bold),
                    ForeColor = Color.White,
                    BackColor = Color.FromArgb(180, 100, 30),
                    FlatStyle = FlatStyle.Flat,
                    Cursor = Cursors.Hand
                };
                btn.Click += LetterButton_Click;

                pnlLetters.Controls.Add(btn);
                _letterButtons.Add(btn);
            }

            pnlLetters.ResumeLayout();
        }

        private void RebuildLetterButtons()
        {
            var letters = _gameBUS.GetAvailableLetters();
            BuildLetterButtons(letters);
        }

        private void ResetAnswerSlots(int slotCount)
        {
            BuildAnswerSlots(slotCount);
        }

        private void UpdateAnswerSlots(List<char> currentInput)
        {
            for (int i = 0; i < _answerSlots.Count; i++)
            {
                if (i < currentInput.Count)
                {
                    _answerSlots[i].Text = currentInput[i].ToString();
                    _answerSlots[i].BackColor = COLOR_SLOT_FILLED;
                }
                else
                {
                    _answerSlots[i].Text = "";
                    _answerSlots[i].BackColor = COLOR_SLOT_DEFAULT;
                }
            }
        }

        private void UpdateLetterButtons(List<char> availableLetters)
        {
            // Cập nhật visibility dựa trên available letters
            foreach (var btn in _letterButtons)
            {
                char letter = btn.Text[0];
                btn.Visible = availableLetters.Contains(letter);
            }
        }

        private void HighlightAllSlots(Color color)
        {
            foreach (var slot in _answerSlots)
            {
                slot.BackColor = color;
            }
        }

        private void ShowCorrectAnswer(string correctAnswer)
        {
            for (int i = 0; i < _answerSlots.Count && i < correctAnswer.Length; i++)
            {
                _answerSlots[i].Text = correctAnswer[i].ToString();
            }
        }

        private Button FindLetterButton(char letter)
        {
            return _letterButtons.Find(b => b.Text[0] == letter && b.Visible);
        }

        #endregion

        #region ==================== Image & Speech ====================

        private void RenderWordImage(string imagePath, string emoji)
        {
            if (picWord.Image != null)
            {
                picWord.Image.Dispose();
                picWord.Image = null;
            }

            if (!string.IsNullOrEmpty(imagePath))
            {
                string fullPath = Path.Combine(Application.StartupPath, imagePath);
                if (File.Exists(fullPath))
                {
                    try
                    {
                        using var fs = new FileStream(fullPath, FileMode.Open, FileAccess.Read, FileShare.Read);
                        using var img = Image.FromStream(fs, true, true);
                        picWord.Image = new Bitmap(img);
                        return;
                    }
                    catch { }
                }
            }

            RenderEmoji(emoji);
        }

        private void RenderEmoji(string emoji)
        {
            int width = picWord.Width > 0 ? picWord.Width : 300;
            int height = picWord.Height > 0 ? picWord.Height : 280;
            var bitmap = new Bitmap(width, height);

            using (var g = Graphics.FromImage(bitmap))
            {
                g.Clear(Color.FromArgb(26, 21, 66));
                using var font = new Font("Segoe UI Emoji", 80);
                var size = g.MeasureString(emoji, font);
                float x = (bitmap.Width - size.Width) / 2;
                float y = (bitmap.Height - size.Height) / 2;
                g.DrawString(emoji, font, Brushes.White, x, y);
            }

            picWord.Image = bitmap;
        }

        private void InitializeSpeech()
        {
            try
            {
                _speechSynthesizer = new SpeechSynthesizer();
                _speechSynthesizer.SelectVoiceByHints(VoiceGender.Female, VoiceAge.Child);
            }
            catch { _speechSynthesizer = null; }
        }

        private void SpeakCurrentWord()
        {
            if (_speechSynthesizer == null) return;

            var question = _gameBUS.GetCurrentQuestion();
            if (question != null && !string.IsNullOrEmpty(question.EnglishWord))
            {
                try
                {
                    _speechSynthesizer.SpeakAsync(question.EnglishWord);
                    lblEnglish.Text = $"{question.Phonetic}  {question.EnglishWord}";
                    lblEnglish.Visible = true;
                }
                catch { }
            }
        }

        #endregion

        #region ==================== Timer & Sound ====================

        private void StartUIRefreshTimer()
        {
            _uiRefreshTimer = new Timer { Interval = 50 };
            _uiRefreshTimer.Tick += (s, e) =>
            {
                var state = _gameBUS.GetCurrentState();
                UpdateUI(state);
            };
            _uiRefreshTimer.Start();
        }

        private void StopUIRefreshTimer()
        {
            _uiRefreshTimer?.Stop();
            _uiRefreshTimer?.Dispose();
        }

        private void UpdateTimerColor(int secondsLeft)
        {
            if (secondsLeft <= 10)
                lblTimer.ForeColor = Color.FromArgb(255, 107, 107);
            else if (secondsLeft <= 20)
                lblTimer.ForeColor = Color.FromArgb(247, 201, 72);
            else
                lblTimer.ForeColor = Color.FromArgb(78, 203, 113);
        }

        private string GetLivesDisplay(int lives, int maxLives)
        {
            return new string('❤', lives) + new string('🖤', maxLives - lives);
        }

        private void PlayCorrectSound()
        {
            try { System.Media.SystemSounds.Asterisk.Play(); } catch { }
        }

        private void PlayWrongSound()
        {
            try { System.Media.SystemSounds.Hand.Play(); } catch { }
        }

        #endregion

        #region ==================== Resource Management ====================

        private void CleanupResources()
        {
            StopUIRefreshTimer();

            if (_speechSynthesizer != null)
            {
                try { _speechSynthesizer.Dispose(); } catch { }
                _speechSynthesizer = null;
            }

            if (picWord.Image != null)
            {
                try { picWord.Image.Dispose(); } catch { }
                picWord.Image = null;
            }
        }

        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            CleanupResources();
            base.OnFormClosing(e);
        }

        #endregion
    }
}