using System;
using System.Drawing;
using System.IO;
using System.Windows.Forms;

namespace WordQuest.GUI.UserControls
{
    public partial class UC_WordItem : UserControl
    {
        private PictureBox picPreview;
        private Label lblEnglish;
        private Label lblVietnamese;
        private Label lblDifficulty;
        private Button btnSelect;

        public event EventHandler? WordSelected;

        public UC_WordItem()
        {
            InitializeComponent();
            BuildControls();
        }

        private void BuildControls()
        {
            this.picPreview = new PictureBox();
            this.lblEnglish = new Label();
            this.lblVietnamese = new Label();
            this.lblDifficulty = new Label();
            this.btnSelect = new Button();
            ((System.ComponentModel.ISupportInitialize)this.picPreview).BeginInit();
            this.SuspendLayout();

            // picPreview
            this.picPreview.BorderStyle = BorderStyle.FixedSingle;
            this.picPreview.Location = new Point(5, 5);
            this.picPreview.Size = new Size(60, 60);
            this.picPreview.SizeMode = PictureBoxSizeMode.Zoom;

            // lblEnglish
            this.lblEnglish.Font = new Font("Segoe UI", 10F, FontStyle.Bold);
            this.lblEnglish.Location = new Point(70, 5);
            this.lblEnglish.Size = new Size(150, 25);

            // lblVietnamese
            this.lblVietnamese.Font = new Font("Segoe UI", 9F);
            this.lblVietnamese.Location = new Point(70, 30);
            this.lblVietnamese.Size = new Size(150, 20);

            // lblDifficulty
            this.lblDifficulty.Font = new Font("Segoe UI", 8F);
            this.lblDifficulty.Location = new Point(70, 50);
            this.lblDifficulty.Size = new Size(100, 20);

            // btnSelect
            this.btnSelect.FlatStyle = FlatStyle.Flat;
            this.btnSelect.Location = new Point(230, 15);
            this.btnSelect.Size = new Size(50, 30);
            this.btnSelect.Text = "Chọn";
            this.btnSelect.Click += (s, e) => WordSelected?.Invoke(this, EventArgs.Empty);

            // UC_WordItem
            this.BorderStyle = BorderStyle.FixedSingle;
            this.Size = new Size(290, 70);
            this.Controls.Add(this.picPreview);
            this.Controls.Add(this.lblEnglish);
            this.Controls.Add(this.lblVietnamese);
            this.Controls.Add(this.lblDifficulty);
            this.Controls.Add(this.btnSelect);

            ((System.ComponentModel.ISupportInitialize)this.picPreview).EndInit();
            this.ResumeLayout(false);
        }

        public void SetWordData(int wordID, string english, string vietnamese, int difficulty, string imagePath)
        {
            this.Tag = wordID;
            lblEnglish.Text = english;
            lblVietnamese.Text = vietnamese;

            string diffText = difficulty switch
            {
                1 => "Dễ",
                2 => "Trung bình",
                3 => "Khó",
                _ => "Không xác định"
            };
            lblDifficulty.Text = $"Độ khó: {diffText}";

            if (!string.IsNullOrEmpty(imagePath))
            {
                string fullPath = Path.Combine(Application.StartupPath, imagePath);
                if (File.Exists(fullPath))
                {
                    try
                    {
                        picPreview.Image = Image.FromFile(fullPath);
                        return;
                    }
                    catch { }
                }
            }
            picPreview.Image = null;
        }
    }
}