using System;
using System.Data;
using System.Drawing;
using System.IO;
using System.Linq;
using System.Windows.Forms;
using WordQuest.BUS;
using WordQuest.DTO;

namespace WordQuest.GUI
{
    public partial class frmAdmin : Form
    {
        private readonly Form _topics;
        private readonly WordBUS _wordBUS = new();
        private readonly TopicBUS _topicBUS = new();
        private readonly ImageBUS _imageBUS = new();

        private int _selectedWordID = -1;
        private string _selectedImagePath = "";

        public frmAdmin(Form topics)
        {
            InitializeComponent();
            _topics = topics;
        }

        private async void frmAdmin_Load(object sender, EventArgs e)
        {
            SetupControls();
            await LoadTopicsToComboBox();
            await LoadWords();
        }

        private void SetupControls()
        {
            cboFilterImage.Items.AddRange(new[] { "Tất cả", "Có ảnh", "Chưa có ảnh", "Đang dùng", "Chưa dùng" });
            cboFilterImage.SelectedIndex = 0;

            cboFilterDiff.Items.AddRange(new[] { "Tất cả", "1", "2", "3" });
            cboFilterDiff.SelectedIndex = 0;

            cboInputDiff.Items.AddRange(new[] { "1", "2", "3" });
            cboInputDiff.SelectedIndex = 0;

            dgvWords.CellClick += DgvWords_CellClick;
            btnAdd.Click += BtnAdd_Click;
            btnUpdate.Click += BtnUpdate_Click;
            btnDelete.Click += BtnDelete_Click;
            btnSearch.Click += BtnSearch_Click;
            btnShowAll.Click += BtnShowAll_Click;
            btnBack.Click += BtnBack_Click;
            btnPickImage.Click += BtnPickImage_Click;

            LoadTopicTree();
        }

        private async Task LoadTopicsToComboBox()
        {
            var dt = await Task.Run(() => _topicBUS.GetAllTopics());
            cboInputTopic.Items.Clear();
            foreach (DataRow row in dt.Rows)
            {
                cboInputTopic.Items.Add(new ComboItem(Convert.ToInt32(row["TopicID"]), row["TopicName"].ToString() ?? ""));
            }
            if (cboInputTopic.Items.Count > 0) cboInputTopic.SelectedIndex = 0;
        }

        private async Task LoadWords(string filterTopic = "", string filterDiff = "", string search = "", string extraSql = "")
        {
            var dt = await Task.Run(() => _wordBUS.SearchWords(search, filterDiff, ""));
            dgvWords.Rows.Clear();

            foreach (DataRow row in dt.Rows)
            {
                dgvWords.Rows.Add(
                    row["WordID"], row["TopicName"], row["EnglishWord"], row["Phonetic"],
                    row["VietnameseMeaning"], row["DifficultyLevel"], row["EmojiIcon"], "🗑", row["ImagePath"]
                );
            }
            label1.Text = $"Quản lý từ vựng | Tổng: {dt.Rows.Count} từ";
        }

        private async void LoadTopicTree()
        {
            treeTopics.Nodes.Clear();
            var allNode = new TreeNode("Tất cả từ vựng") { Tag = -1 };
            treeTopics.Nodes.Add(allNode);

            var dt = await Task.Run(() => _topicBUS.GetParentTopics());
            foreach (DataRow row in dt.Rows)
            {
                var parentNode = new TreeNode(row["TopicName"].ToString()) { Tag = row["TopicID"] };
                treeTopics.Nodes.Add(parentNode);
            }
            treeTopics.ExpandAll();
            treeTopics.SelectedNode = allNode;
        }

        private async void treeTopics_AfterSelect(object sender, TreeViewEventArgs e)
        {
            if (e.Node?.Tag == null) return;
            int topicID = Convert.ToInt32(e.Node.Tag);
            if (topicID == -1) await LoadWords();
            else await LoadWords(topicID.ToString(), "", "");
        }

        private void DgvWords_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;
            if (dgvWords.Columns[e.ColumnIndex].Name == "colErase")
            {
                int wordID = Convert.ToInt32(dgvWords.Rows[e.RowIndex].Cells["colID"].Value);
                DeleteWord(wordID);
                return;
            }
            LoadRowToInput(e.RowIndex);
        }

        private void LoadRowToInput(int rowIndex)
        {
            var row = dgvWords.Rows[rowIndex];
            _selectedWordID = Convert.ToInt32(row.Cells["colID"].Value);

            string topicName = row.Cells["colTopic"].Value?.ToString() ?? "";
            foreach (ComboItem item in cboInputTopic.Items)
            {
                if (item.Name == topicName) { cboInputTopic.SelectedItem = item; break; }
            }

            txtEnglish.Text = row.Cells["colEnglish"].Value?.ToString() ?? "";
            txtPhonetic.Text = row.Cells["colPhonetic"].Value?.ToString() ?? "";
            txtVietnamese.Text = row.Cells["colVietnamese"].Value?.ToString() ?? "";
            txtHint.Text = row.Cells["colEmojiIcon"].Value?.ToString() ?? "";

            string diff = row.Cells["colDifficulty"].Value?.ToString() ?? "";
            int diffIdx = cboInputDiff.Items.IndexOf(diff);
            if (diffIdx >= 0) cboInputDiff.SelectedIndex = diffIdx;

            _selectedImagePath = row.Cells["colImagePath"].Value?.ToString() ?? "";
            if (!string.IsNullOrEmpty(_selectedImagePath))
            {
                string fullPath = Path.Combine(Application.StartupPath, _selectedImagePath);
                if (File.Exists(fullPath)) picPreview.Image = Image.FromFile(fullPath);
            }
        }

        private async void BtnAdd_Click(object sender, EventArgs e)
        {
            if (!ValidateInput()) return;

            var word = new WordDTO
            {
                TopicID = ((ComboItem)cboInputTopic.SelectedItem).ID,
                EnglishWord = txtEnglish.Text.Trim(),
                Phonetic = txtPhonetic.Text.Trim(),
                VietnameseMeaning = txtVietnamese.Text.Trim(),
                DifficultyLevel = int.Parse(cboInputDiff.SelectedItem.ToString()!),
                EmojiIcon = txtHint.Text.Trim(),
                ImagePath = _selectedImagePath
            };

            try
            {
                int newID = await Task.Run(() => _wordBUS.AddWord(word));
                await LoadWords();
                ClearInput();
                MessageBox.Show("Thêm từ thành công!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Lỗi: {ex.Message}", "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async void BtnUpdate_Click(object sender, EventArgs e)
        {
            if (_selectedWordID < 0) { MessageBox.Show("Chọn từ cần sửa!"); return; }
            if (!ValidateInput()) return;

            var word = new WordDTO
            {
                WordID = _selectedWordID,
                TopicID = ((ComboItem)cboInputTopic.SelectedItem).ID,
                EnglishWord = txtEnglish.Text.Trim(),
                Phonetic = txtPhonetic.Text.Trim(),
                VietnameseMeaning = txtVietnamese.Text.Trim(),
                DifficultyLevel = int.Parse(cboInputDiff.SelectedItem.ToString()!),
                EmojiIcon = txtHint.Text.Trim(),
                ImagePath = _selectedImagePath
            };

            try
            {
                await Task.Run(() => _wordBUS.UpdateWord(word));
                await LoadWords();
                ClearInput();
                MessageBox.Show("Cập nhật thành công!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Lỗi: {ex.Message}", "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async void DeleteWord(int wordID)
        {
            var confirm = MessageBox.Show("Xóa từ này?", "Xác nhận", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
            if (confirm != DialogResult.Yes) return;

            try
            {
                await Task.Run(() => _wordBUS.DeleteWord(wordID));
                await LoadWords();
                ClearInput();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Lỗi: {ex.Message}", "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void BtnDelete_Click(object sender, EventArgs e) => DeleteWord(_selectedWordID);

        private async void BtnSearch_Click(object sender, EventArgs e)
        {
            await LoadWords("", cboFilterDiff.SelectedItem?.ToString() ?? "Tất cả", txtSearch.Text.Trim());
        }

        private async void BtnShowAll_Click(object sender, EventArgs e)
        {
            cboFilterImage.SelectedIndex = 0;
            cboFilterDiff.SelectedIndex = 0;
            txtSearch.Text = "";
            await LoadWords();
            ClearInput();
        }

        private void BtnPickImage_Click(object sender, EventArgs e)
        {
            using var frm = new frmImage();
            if (frm.ShowDialog() == DialogResult.OK)
            {
                _selectedImagePath = frm.SelectedImagePath;
                string fullPath = Path.Combine(Application.StartupPath, _selectedImagePath);
                if (File.Exists(fullPath)) picPreview.Image = Image.FromFile(fullPath);
            }
        }

        private void BtnBack_Click(object sender, EventArgs e)
        {
            _topics.Show();
            this.Close();
        }

        private bool ValidateInput()
        {
            if (cboInputTopic.SelectedItem == null) { MessageBox.Show("Chọn chủ đề!"); return false; }
            if (string.IsNullOrWhiteSpace(txtEnglish.Text)) { MessageBox.Show("Nhập tiếng Anh!"); return false; }
            if (string.IsNullOrWhiteSpace(txtVietnamese.Text)) { MessageBox.Show("Nhập tiếng Việt!"); return false; }
            return true;
        }

        private void ClearInput()
        {
            _selectedWordID = -1;
            txtEnglish.Text = "";
            txtPhonetic.Text = "";
            txtVietnamese.Text = "";
            txtHint.Text = "";
            _selectedImagePath = "";
            picPreview.Image = null;
        }

        private void treeTopics_MouseDown(object sender, MouseEventArgs e)
        {
            var node = treeTopics.GetNodeAt(e.X, e.Y);
            if (node != null) treeTopics.SelectedNode = node;
        }

        private void btnPickImage_Click(object sender, EventArgs e) => BtnPickImage_Click(sender, e);
    }

    public class ComboItem
    {
        public int ID { get; set; }
        public string Name { get; set; }
        public ComboItem(int id, string name) { ID = id; Name = name; }
        public override string ToString() => Name;
    }
}