using System;
using System.Collections.Generic;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Speech.Synthesis;
using System.Windows.Forms;
using WinTimer = System.Windows.Forms.Timer;

namespace WordQuest
{
    public partial class frmGame : Form
    {
        private readonly int playerID;
        private readonly string username;
        private readonly int topicID;
        private readonly string topicName;
        private readonly string topicEmoji;
        private readonly int levelNum;
        private readonly string gameMode;
        private readonly int levelID;

        private readonly GameRepository gameRepository = new();

        private DataTable wordTable = new();
        private int currentWordIndex = 0;
        private string currentAnswer = string.Empty;
        private string currentImagePath = "";

        private readonly List<string> filledLetters = new();
        private readonly List<Button> answerSlots = new();
        private readonly List<Button> letterButtons = new();

        private GameRule currentRule = new();

        private int lives;
        private int streak;
        private int score;
        private int timeLeft;
        private int correctCount;
        private int totalTimeSpent;
        private bool answered;
        private void RenderWordImage(string imagePath, string emoji);

        public frmGame(
            int playerID,
            string username,
            int topicID,
            string topicName,
            string topicEmoji,
            int levelNum,
            string gameMode,
            int levelID)
        {
            InitializeComponent();

            this.playerID = playerID;
            this.username = username;
            this.topicID = topicID;
            this.topicName = topicName;
            this.topicEmoji = topicEmoji;
            this.levelNum = levelNum;
            this.gameMode = gameMode;
            this.levelID = levelID;
        }

        private void frmGame_Load(object sender, EventArgs e)
        {
            InitializeGame();

        }

        private void InitializeGame()
        {
            currentRule = gameRepository.GetGameRule();

            lives = currentRule.Lives;
            streak = 0;
            score = 0;
            correctCount = 0;
            totalTimeSpent = 0;
            currentWordIndex = 0;

            SetupUI();
            LoadWords();

            if (wordTable.Rows.Count == 0)
            {
                MessageBox.Show("Không có dữ liệu câu hỏi cho màn này!", "Thông báo",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                Close();
                return;
            }

            ShowCurrentWord();
        }

        private void SetupUI()
        {
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = Color.FromArgb(101, 67, 33);

            pnlHeader.BackColor = Color.FromArgb(75, 45, 15);
            picWord.BackColor = Color.FromArgb(120, 80, 40);
            pnlAnswer.BackColor = Color.Transparent;
            pnlLetters.BackColor = Color.Transparent;

            lblTopic.Text = $"{topicEmoji} {topicName} - Màn {levelNum}";
            lblTopic.ForeColor = Color.FromArgb(247, 201, 72);
            lblTopic.Font = new Font("Segoe UI", 13, FontStyle.Bold);

            lblStreak.Text = "🔥 0";
            lblStreak.ForeColor = Color.FromArgb(247, 201, 72);
            lblStreak.Font = new Font("Segoe UI", 12, FontStyle.Bold);

            lblQuestion.ForeColor = Color.White;
            lblQuestion.Font = new Font("Segoe UI", 11, FontStyle.Bold);

            lblTimer.ForeColor = Color.FromArgb(78, 203, 113);
            lblTimer.Font = new Font("Segoe UI", 12, FontStyle.Bold);

            lblEnglish.Text = "";
            lblEnglish.Visible = false;
            lblEnglish.Font = new Font("Segoe UI", 16, FontStyle.Bold);
            lblEnglish.ForeColor = Color.FromArgb(78, 203, 113);
            lblEnglish.TextAlign = ContentAlignment.MiddleCenter;

            btnHint.BackColor = Color.FromArgb(247, 201, 72);
            btnHint.ForeColor = Color.FromArgb(15, 12, 41);
            btnHint.FlatStyle = FlatStyle.Flat;
            btnHint.FlatAppearance.BorderSize = 0;
            btnHint.Font = new Font("Segoe UI", 10, FontStyle.Bold);
            btnHint.Cursor = Cursors.Hand;

            btnExit.BackColor = Color.FromArgb(75, 45, 15);
            btnExit.ForeColor = Color.FromArgb(255, 200, 100);
            btnExit.FlatAppearance.BorderColor = Color.FromArgb(78, 203, 113);
            btnExit.FlatAppearance.BorderSize = 2;
            btnExit.Cursor = Cursors.Hand;

            gameTimer.Interval = 1000;

            UpdateLivesUI();
            ResetTimerUI();

        }

        private void RenderWordImage(string imagePath, string emoji)
        {
            if (!string.IsNullOrEmpty(imagePath))
            {
                string fullPath = Path.Combine(Application.StartupPath, imagePath);
                if (File.Exists(fullPath))
                {
                    picWord.Image = Image.FromFile(fullPath);
                    picWord.SizeMode = PictureBoxSizeMode.Zoom;
                    picWord.BackColor = Color.FromArgb(26, 21, 66);
                    return;
                }
            }

            // Fallback — vẽ emoji như cũ
            RenderEmoji(emoji);
        }

        // frmGame.cs

        private void LoadWords()
        {
            wordTable = gameRepository.GetWordsByLevelID(levelID);
            currentWordIndex = 0;
        }

        private void ShowCurrentWord()
        {
            lblEnglish.Visible = false;

            if (currentWordIndex >= wordTable.Rows.Count)
            {
                EndGame();
                return;
            }

            answered = false;

            DataRow row = wordTable.Rows[currentWordIndex];
            currentAnswer = GetCurrentAnswer(row);

            lblQuestion.Text = $"Câu {currentWordIndex + 1}/{wordTable.Rows.Count}";

            // ✅ Ưu tiên ảnh thật, fallback về emoji
            string imgPath = row["ImagePath"]?.ToString() ?? "";
            string emoji = row["EmojiIcon"]?.ToString() ?? "";
            RenderWordImage(imgPath, emoji);

            BuildAnswerSlots();
            BuildLetterButtons();
            ResetTimerForNewQuestion();
        }

        private string GetCurrentAnswer(DataRow row)
        {
            string raw = gameMode == "VI"
                ? row["VietnameseMeaning"]?.ToString() ?? ""
                : row["EnglishWord"]?.ToString() ?? "";

            return raw.Trim().ToUpper();
        }

        private void RenderEmoji(string emoji)
        {
            int width = picWord.Width > 0 ? picWord.Width : 300;
            int height = picWord.Height > 0 ? picWord.Height : 280;

            Bitmap bmp = new(width, height);

            using (Graphics g = Graphics.FromImage(bmp))
            {
                g.Clear(Color.FromArgb(26, 21, 66));

                using Font font = new("Segoe UI Emoji", 80);
                SizeF size = g.MeasureString(emoji, font);

                float x = (bmp.Width - size.Width) / 2;
                float y = (bmp.Height - size.Height) / 2;

                g.DrawString(emoji, font, Brushes.White, x, y);
            }

            picWord.Image = bmp;
        }

        private void BuildAnswerSlots()
        {
            pnlAnswer.Controls.Clear();
            answerSlots.Clear();
            filledLetters.Clear();

            char[] chars = currentAnswer.ToCharArray();
            int slotW = 45, slotH = 50, gap = 6;
            int totalW = chars.Length * (slotW + gap);
            int startX = Math.Max(5, (pnlAnswer.Width - totalW) / 2);

            for (int i = 0; i < chars.Length; i++)
            {
                if (chars[i] == ' ')
                {
                    Label space = new()
                    {
                        Size = new Size(15, slotH),
                        Location = new Point(startX + i * (slotW + gap), 5)
                    };
                    pnlAnswer.Controls.Add(space);
                    continue;
                }

                Button slot = new()
                {
                    Size = new Size(slotW, slotH),
                    Location = new Point(startX + i * (slotW + gap), 5),
                    Text = "",
                    Font = new Font("Segoe UI", 14, FontStyle.Bold),
                    ForeColor = Color.White,
                    BackColor = Color.FromArgb(139, 90, 43),
                    FlatStyle = FlatStyle.Flat,
                    Enabled = true,
                    Tag = i
                };

                slot.FlatAppearance.BorderColor = Color.FromArgb(210, 150, 80);
                slot.FlatAppearance.BorderSize = 2;
                slot.Click += AnswerSlot_Click;

                pnlAnswer.Controls.Add(slot);
                answerSlots.Add(slot);
            }
        }

        private void BuildLetterButtons()
        {
            pnlLetters.Controls.Clear();
            letterButtons.Clear();

            string answerWithoutSpaces = currentAnswer.Replace(" ", "");
            List<string> letters = answerWithoutSpaces
                .ToCharArray()
                .Select(c => c.ToString())
                .ToList();

            Random rnd = new();
            string extra = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

            int noiseCount = Math.Max(0, 12 - letters.Count);
            noiseCount = Math.Min(noiseCount, 4);

            for (int i = 0; i < noiseCount; i++)
            {
                letters.Add(extra[rnd.Next(extra.Length)].ToString());
            }

            List<string> shuffled = letters.OrderBy(_ => rnd.Next()).ToList();

            int btnW = 55, btnH = 55, gap = 8;
            int totalW = shuffled.Count * (btnW + gap);
            int startX = Math.Max(5, (pnlLetters.Width - totalW) / 2);

            for (int i = 0; i < shuffled.Count; i++)
            {
                Button btn = new()
                {
                    Size = new Size(btnW, btnH),
                    Location = new Point(startX + i * (btnW + gap), 5),
                    Text = shuffled[i],
                    Font = new Font("Segoe UI", 16, FontStyle.Bold),
                    ForeColor = Color.White,
                    BackColor = Color.FromArgb(180, 100, 30),
                    FlatStyle = FlatStyle.Flat,
                    Cursor = Cursors.Hand,
                    Tag = i
                };

                btn.FlatAppearance.BorderSize = 0;
                btn.Click += LetterButton_Click;

                pnlLetters.Controls.Add(btn);
                letterButtons.Add(btn);
            }
        }

        private void LetterButton_Click(object? sender, EventArgs e)
        {
            if (answered || sender is not Button btn)
                return;

            int nextSlotIndex = filledLetters.Count;
            if (nextSlotIndex >= answerSlots.Count)
                return;

            filledLetters.Add(btn.Text);
            answerSlots[nextSlotIndex].Text = btn.Text;
            answerSlots[nextSlotIndex].BackColor = Color.FromArgb(50, 45, 100);
            answerSlots[nextSlotIndex].Tag = btn;
            btn.Visible = false;

            if (filledLetters.Count == answerSlots.Count)
                CheckAnswer();
        }

        private void AnswerSlot_Click(object? sender, EventArgs e)
        {
            if (answered || sender is not Button slot)
                return;

            int slotIndex = answerSlots.IndexOf(slot);
            if (slotIndex < 0 || slotIndex >= filledLetters.Count)
                return;

            for (int i = filledLetters.Count - 1; i >= slotIndex; i--)
            {
                if (answerSlots[i].Tag is Button originalButton)
                    originalButton.Visible = true;

                answerSlots[i].Text = "";
                answerSlots[i].BackColor = Color.FromArgb(30, 26, 74);
                answerSlots[i].Tag = i;

                filledLetters.RemoveAt(i);
            }
        }

        private void CheckAnswer()
        {
            answered = true;
            gameTimer.Stop();

            string userAnswer = string.Join("", filledLetters);
            string correctAnswer = currentAnswer.Replace(" ", "");

            if (userAnswer == correctAnswer)
                HandleCorrectAnswer();
            else
                HandleWrongAnswer();
        }

        private void HandleCorrectAnswer()
        {
            PlayCorrectSound();

            streak++;
            correctCount++;
            score += 10 + (streak >= 3 ? currentRule.StreakBonus : 0);

            lblStreak.Text = $"🔥 {streak}";

            foreach (Button slot in answerSlots)
                slot.BackColor = Color.FromArgb(78, 203, 113);

            SpeakCurrentWord();
            ShowEnglishInfo();

            StartDelay(3000, () =>
            {
                currentWordIndex++;
                ShowCurrentWord();
            });
        }

        private void HandleWrongAnswer()
        {
            PlayWrongSound();

            streak = 0;
            lives--;

            lblStreak.Text = "🔥 0";
            UpdateLivesUI();

            foreach (Button slot in answerSlots)
                slot.BackColor = Color.FromArgb(255, 107, 107);

            StartDelay(1000, () =>
            {
                ShowCorrectAnswer();

                StartDelay(1500, () =>
                {
                    if (lives <= 0)
                        EndGame();
                    else
                    {
                        currentWordIndex++;
                        ShowCurrentWord();
                    }
                });
            });
        }

        private void ShowCorrectAnswer()
        {
            string correct = currentAnswer.Replace(" ", "");

            for (int i = 0; i < answerSlots.Count; i++)
            {
                answerSlots[i].Text = i < correct.Length ? correct[i].ToString() : "";
                answerSlots[i].BackColor = Color.FromArgb(78, 203, 113);
            }
        }

        private void ShowEnglishInfo()
        {
            string englishWord = wordTable.Rows[currentWordIndex]["EnglishWord"]?.ToString() ?? "";
            string phonetic = wordTable.Rows[currentWordIndex]["Phonetic"]?.ToString() ?? "";

            lblEnglish.Text = $"{phonetic}  {englishWord}";
            lblEnglish.Visible = true;
        }

        private void SpeakCurrentWord()
        {
            try
            {
                string englishWord = wordTable.Rows[currentWordIndex]["EnglishWord"]?.ToString() ?? "";
                using SpeechSynthesizer synth = new();
                synth.SelectVoiceByHints(VoiceGender.Female, VoiceAge.Child);
                synth.SpeakAsync(englishWord);
            }
            catch
            {
                // Có thể log nếu cần
            }
        }

        private void btnHint_Click(object sender, EventArgs e)
        {
            int nextSlotIndex = filledLetters.Count;
            if (nextSlotIndex >= answerSlots.Count)
                return;

            string correct = currentAnswer.Replace(" ", "");
            string hintLetter = correct[nextSlotIndex].ToString();

            foreach (Button btn in letterButtons)
            {
                if (btn.Visible && btn.Text == hintLetter)
                {
                    LetterButton_Click(btn, EventArgs.Empty);
                    score = Math.Max(0, score - 3);
                    break;
                }
            }
        }

        private void gameTimer_Tick(object sender, EventArgs e)
        {
            timeLeft--;
            totalTimeSpent++;

            pbTime.Value = Math.Max(0, timeLeft);
            lblTimer.Text = $"{timeLeft}s";

            if (timeLeft <= 10)
                lblTimer.ForeColor = Color.FromArgb(255, 107, 107);
            else if (timeLeft <= 20)
                lblTimer.ForeColor = Color.FromArgb(247, 201, 72);
            else
                lblTimer.ForeColor = Color.FromArgb(78, 203, 113);

            if (timeLeft <= 0)
            {
                gameTimer.Stop();
                lives--;
                UpdateLivesUI();

                ShowCorrectAnswer();

                StartDelay(1500, () =>
                {
                    if (lives <= 0)
                        EndGame();
                    else
                    {
                        currentWordIndex++;
                        ShowCurrentWord();
                    }
                });
            }
        }

        private void ResetTimerForNewQuestion()
        {
            timeLeft = currentRule.TimeLimit;
            ResetTimerUI();
            gameTimer.Start();
        }

        private void ResetTimerUI()
        {
            pbTime.Minimum = 0;
            pbTime.Maximum = currentRule.TimeLimit;
            pbTime.Value = currentRule.TimeLimit;
            lblTimer.Text = $"{currentRule.TimeLimit}s";
            lblTimer.ForeColor = Color.FromArgb(78, 203, 113);
        }

        private void UpdateLivesUI()
        {
            int maxLives = Math.Max(1, currentRule.Lives);
            lblLives.Text = string.Concat(
                Enumerable.Range(0, maxLives)
                    .Select(i => i < lives ? "❤️" : "🖤"));
        }

        private int CalculateStars()
        {
            if (correctCount >= currentRule.Star3Threshold)
                return 3;
            if (correctCount >= currentRule.Star2Threshold)
                return 2;
            if (correctCount >= currentRule.Star1Threshold)
                return 1;

            return 0;
        }

        private void EndGame()
        {
            gameTimer.Stop();

            int stars = CalculateStars();

            try
            {
                gameRepository.SaveProgress(playerID, topicID, levelNum, score, stars);
                gameRepository.SaveScoreHistory(playerID, topicID, levelNum, score, stars, totalTimeSpent);
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi lưu tiến độ: " + ex.Message,
                    "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }

            frmWin winForm = new(
                playerID,
                username,
                topicID,
                topicName,
                topicEmoji,
                levelNum,
                score,
                stars,
                correctCount,
                totalTimeSpent,
                wordTable.Rows.Count,
                gameMode);

            winForm.Owner = this.Owner;
            winForm.Show();
            this.Close();
        }

        private void btnExit_Click(object sender, EventArgs e)
        {
            gameTimer.Stop();

            DialogResult result = MessageBox.Show(
                "Bạn có chắc muốn thoát?\nTiến độ sẽ không được lưu!",
                "Thoát game",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question);

            if (result == DialogResult.Yes)
            {
                if (this.Owner != null)
                    this.Owner.Show();

                Close();
            }
            else
            {
                gameTimer.Start();
            }
        }

        private void StartDelay(int milliseconds, Action action)
        {
            WinTimer timer = new WinTimer
            {
                Interval = milliseconds
            };

            timer.Tick += (s, e) =>
            {
                timer.Stop();
                timer.Dispose();
                action();
            };

            timer.Start();
        }

        private void PlayCorrectSound()
        {
            System.Media.SystemSounds.Asterisk.Play();
        }

        private void PlayWrongSound()
        {
            System.Media.SystemSounds.Hand.Play();
        }
    }
