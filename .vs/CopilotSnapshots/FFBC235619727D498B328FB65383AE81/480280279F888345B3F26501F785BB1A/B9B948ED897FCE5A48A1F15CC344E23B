        private void btnTab1_Click(object sender, EventArgs e) => ShowTab(1);
        private void btnTab2_Click(object sender, EventArgs e) => ShowTab(2);

        private void ShowTab(int tab)
        {
            pnlLibrary.Visible = (tab == 1);
            pnlPixabay.Visible = (tab == 2);

            // Màu nút tab
            Color activeBack = Color.FromArgb(37, 99, 176);
            Color inactiveBack = Color.FromArgb(220, 220, 230);

            btnTab1.BackColor = tab == 1 ? activeBack : inactiveBack;
            btnTab2.BackColor = tab == 2 ? activeBack : inactiveBack;
            btnTab1.ForeColor = tab == 1 ? Color.White : Color.FromArgb(80, 80, 80);
            btnTab2.ForeColor = tab == 2 ? Color.White : Color.FromArgb(80, 80, 80);
        }

        // ═══════════════════════════════════════════
        //  TAB 1 — THƯ VIỆN ẢNH
        // ═══════════════════════════════════════════
        private void LoadLibrary(string keyword = "", string filter = "Tất cả")
        {
            lvImages.Items.Clear();
            imgListLarge.Images.Clear();

            string sql = @"
                SELECT i.ImageID, i.ImageName, i.ImagePath,
                       CASE WHEN EXISTS (
                           SELECT 1 FROM Words w WHERE w.ImagePath = i.ImagePath
                       ) THEN 1 ELSE 0 END AS IsUsed
                FROM Images i
                WHERE (@keyword = '' OR i.ImageName LIKE '%' + @keyword + '%')
                ORDER BY i.ImageName";

            DataTable dt = DatabaseHelper.ExecuteQuery(sql,
                new SqlParameter("@keyword", keyword));

            foreach (DataRow row in dt.Rows)
            {
                bool isUsed = Convert.ToInt32(row["IsUsed"]) == 1;
                string imagePath = row["ImagePath"].ToString();
                string imageName = row["ImageName"].ToString();
                int imageID = Convert.ToInt32(row["ImageID"]);

                // Lọc theo trạng thái
                if (filter == "Đang dùng" && !isUsed) continue;
                if (filter == "Chưa dùng" && isUsed) continue;

                // Load ảnh từ file
                string fullPath = Path.Combine(Application.StartupPath, imagePath);
                Image img = File.Exists(fullPath)
                    ? Image.FromFile(fullPath)
                    : SystemIcons.Question.ToBitmap();

                string key = imageID.ToString();
                imgListLarge.Images.Add(key, img);

                ListViewItem item = new(imageName)
                {
                    ImageKey = key,
                    Tag = row
                };

                // Badge màu theo trạng thái
                item.ForeColor = isUsed
                    ? Color.FromArgb(29, 78, 216)
                    : Color.FromArgb(120, 120, 120);

                lvImages.Items.Add(item);
            }

            lblStatusBar.Text =
                $"Tổng: {lvImages.Items.Count} ảnh  ·  " +
                $"{CountUsed(dt)} đang dùng  ·  " +
                $"{dt.Rows.Count - CountUsed(dt)} chưa dùng";
        }

        private int CountUsed(DataTable dt)
        {
            int count = 0;
            foreach (DataRow row in dt.Rows)
                if (Convert.ToInt32(row["IsUsed"]) == 1) count++;
            return count;
        }

        // Thêm ảnh từ máy
        private void btnAddImage_Click(object sender, EventArgs e)
        {
            using OpenFileDialog dlg = new();
            dlg.Filter = "Image Files|*.png;*.jpg;*.jpeg;*.bmp";
            dlg.Title = "Chọn ảnh";

            if (dlg.ShowDialog() != DialogResult.OK) return;

            string fileName = Path.GetFileName(dlg.FileName);
            string destPath = Path.Combine(imagesFolder, fileName);
            string relativePath = Path.Combine("Images", fileName);
            string imageName = Path.GetFileNameWithoutExtension(fileName);

            // Copy file
            File.Copy(dlg.FileName, destPath, overwrite: true);

            // Kiểm tra đã có trong DB chưa
            object exists = DatabaseHelper.ExecuteScalar(
                "SELECT COUNT(1) FROM Images WHERE ImagePath = @path",
                new SqlParameter("@path", relativePath));

            if (Convert.ToInt32(exists) == 0)
            {
                DatabaseHelper.ExecuteNonQuery(
                    "INSERT INTO Images (ImageName, ImagePath) VALUES (@name, @path)",
                    new SqlParameter("@name", imageName),
                    new SqlParameter("@path", relativePath));
            }

            LoadLibrary();
        }

        // Xóa ảnh đã chọn
        private void btnDeleteImage_Click(object sender, EventArgs e)
        {
            if (lvImages.SelectedItems.Count == 0)
            {
                MessageBox.Show("Vui lòng chọn ảnh cần xóa!", "Thông báo",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            DataRow row = (DataRow)lvImages.SelectedItems[0].Tag;
            string imagePath = row["ImagePath"].ToString();
            bool isUsed = Convert.ToInt32(row["IsUsed"]) == 1;
            int imageID = Convert.ToInt32(row["ImageID"]);

            if (isUsed)
            {
                MessageBox.Show("Ảnh này đang được dùng bởi một từ vựng!\nKhông thể xóa.",
                    "Không thể xóa", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            DialogResult confirm = MessageBox.Show(
                $"Xóa ảnh '{row["ImageName"]}' khỏi thư viện và máy?",
                "Xác nhận xóa", MessageBoxButtons.YesNo, MessageBoxIcon.Question);

            if (confirm != DialogResult.Yes) return;

            // Xóa file
            string fullPath = Path.Combine(Application.StartupPath, imagePath);
            if (File.Exists(fullPath)) File.Delete(fullPath);

            // Xóa DB
            DatabaseHelper.ExecuteNonQuery(
                "DELETE FROM Images WHERE ImageID = @id",
                new SqlParameter("@id", imageID));

            picPreview.Image = null;
            lblFileName.Text = "Tên file:";
            lblFilePath.Text = "Đường dẫn:";
            lblFileStatus.Text = "Trạng thái:";

            LoadLibrary();
        }

