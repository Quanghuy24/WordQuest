        // ═══════════════════════════════════════════
        //  TAB 2 — PIXABAY
        // ═══════════════════════════════════════════
        private async void btnPixSearch_Click(object sender, EventArgs e)
        {
            string keyword = txtPixSearch.Text.Trim();
            if (string.IsNullOrEmpty(keyword))
            {
                MessageBox.Show("Vui lòng nhập từ tiếng Anh!", "Thông báo",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            btnPixSearch.Enabled = false;
            btnPixSearch.Text = "Đang tìm...";
            lvPixResult.Items.Clear();
            imgListPixabay.Images.Clear();

            try
            {
                string url = $"https://pixabay.com/api/?key={PixabayApiKey}" +
                             $"&q={Uri.EscapeDataString(keyword)}" +
                             $"&image_type=illustration&per_page=15&safesearch=true";

                string json = await httpClient.GetStringAsync(url);
                var document = JsonDocument.Parse(json);
                var hits = document.RootElement.GetProperty("hits");

                int index = 0;
                foreach (var hit in hits.EnumerateArray())
                {
                    string previewUrl = hit.GetProperty("previewURL").GetString() ?? "";
                    string tags = hit.GetProperty("tags").GetString() ?? "";
                    int pixID = hit.GetProperty("id").GetInt32();

                    // Tải ảnh thumbnail
                    byte[] imgBytes = await httpClient.GetByteArrayAsync(previewUrl);
                    using MemoryStream ms = new(imgBytes);
                    Image img = Image.FromStream(ms);

                    string key = $"pix_{index}";
                    imgListPixabay.Images.Add(key, img);

                    ListViewItem item = new(tags.Length > 15 ? tags[..15] + "..." : tags)
                    {
                        ImageKey = key,
                        Tag = new PixabayResult
                        {
                            PixID = pixID,
                            Tags = tags,
                            PreviewURL = previewUrl,
                            FullURL = hit.GetProperty("largeImageURL").GetString() ?? previewUrl
                        }
                    };

                    lvPixResult.Items.Add(item);
                    index++;
                }

                if (lvPixResult.Items.Count == 0)
                    MessageBox.Show("Không tìm thấy ảnh phù hợp!", "Thông báo",
                        MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (HttpRequestException)
            {
                MessageBox.Show("Không có kết nối mạng hoặc API key chưa đúng!\n" +
                                "Tab 1 (Thư viện) vẫn dùng được offline.",
                    "Lỗi kết nối", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi: " + ex.Message, "Lỗi",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                btnPixSearch.Enabled = true;
                btnPixSearch.Text = "🔍 Tìm ảnh trên Pixabay";
            }
        }

        // Click ảnh Pixabay → xem trước
        private void lvPixResult_SelectedIndexChanged(object sender, EventArgs e)
        {
            if (lvPixResult.SelectedItems.Count == 0) return;

            var result = (PixabayResult)lvPixResult.SelectedItems[0].Tag;

            // Hiện ảnh preview từ ImageList
            string key = lvPixResult.SelectedItems[0].ImageKey;
            if (imgListPixabay.Images.ContainsKey(key))
                picPreview.Image = imgListPixabay.Images[key];

            lblFileName.Text = $"Tên file: {result.Tags}";
            lblFilePath.Text = $"Nguồn: Pixabay #{result.PixID}";
            lblFileStatus.Text = "Trạng thái: Chưa tải về";
        }

        // Tải ảnh Pixabay về thư viện
        private async void btnDownload_Click(object sender, EventArgs e)
        {
            if (lvPixResult.SelectedItems.Count == 0)
            {
                MessageBox.Show("Vui lòng chọn ảnh cần tải!", "Thông báo",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var result = (PixabayResult)lvPixResult.SelectedItems[0].Tag;
            string fileName = $"pixabay_{result.PixID}.jpg";
            string destPath = Path.Combine(imagesFolder, fileName);
            string relPath = Path.Combine("Images", fileName);

            btnDownload.Enabled = false;
            btnDownload.Text = "Đang tải...";

            try
            {
                // Tải ảnh full
                byte[] imgBytes = await httpClient.GetByteArrayAsync(result.FullURL);
                await File.WriteAllBytesAsync(destPath, imgBytes);

                // Lưu vào DB
                string imageName = result.Tags.Split(',')[0].Trim();

                object exists = DatabaseHelper.ExecuteScalar(
                    "SELECT COUNT(1) FROM Images WHERE ImagePath = @path",
                    new SqlParameter("@path", relPath));

                if (Convert.ToInt32(exists) == 0)
                {
                    DatabaseHelper.ExecuteNonQuery(
                        "INSERT INTO Images (ImageName, ImagePath) VALUES (@name, @path)",
                        new SqlParameter("@name", imageName),
                        new SqlParameter("@path", relPath));
                }

                MessageBox.Show($"Đã tải và lưu ảnh '{imageName}' vào thư viện!",
                    "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);

                // Chuyển sang Tab 1 để thấy ảnh vừa tải
                ShowTab(1);
                LoadLibrary();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi tải ảnh: " + ex.Message, "Lỗi",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                btnDownload.Enabled = true;
                btnDownload.Text = "⬇ Tải về & lưu vào thư viện";
            }
        }

        // ═══════════════════════════════════════════
        //  XEM TRƯỚC & CHỌN ẢNH
        // ═══════════════════════════════════════════
        private void ShowPreview(string imagePath, string fileName, bool isUsed)
        {
            string fullPath = Path.Combine(Application.StartupPath, imagePath);

            picPreview.Image = File.Exists(fullPath)
                ? Image.FromFile(fullPath)
                : null;

            lblFileName.Text = $"Tên file:     {fileName}";
            lblFilePath.Text = $"Đường dẫn:  {imagePath}";
            lblFileStatus.Text = isUsed
                ? "Trạng thái:  Đang dùng"
                : "Trạng thái:  Chưa dùng";
        }

        // Nút "Chọn ảnh" → trả về frmAdmin
        private void btnSelectImage_Click(object sender, EventArgs e)
        {
            // Tab 1 đang active
            if (pnlLibrary.Visible)
            {
                if (lvImages.SelectedItems.Count == 0)
                {
                    MessageBox.Show("Vui lòng chọn ảnh trong thư viện!", "Thông báo",
                        MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }

                DataRow row = (DataRow)lvImages.SelectedItems[0].Tag;
                SelectedImagePath = row["ImagePath"].ToString();
            }
            // Tab 2 đang active — phải tải về trước
            else
            {
                if (string.IsNullOrEmpty(SelectedImagePath))
                {
                    MessageBox.Show("Vui lòng tải ảnh Pixabay về thư viện trước!",
                        "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
            }

            this.DialogResult = DialogResult.OK;
            this.Close();
        }

