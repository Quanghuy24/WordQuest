        private void ApplyFilter()
        {
            string topic = "";
            if (cboFilterTopic.SelectedItem is ComboItem item && item.ID != 0)
                topic = item.Name;

            string diff = cboFilterDiff.SelectedItem?.ToString() ?? "";
            string search = txtSearch.Text.Trim();

            LoadWords(topic, diff, search);
        }

        // ===================== GRID CLICK =====================
        private void dgvWords_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;

            // Nút Xóa trong cột colErase
            if (dgvWords.Columns[e.ColumnIndex].Name == "colErase")
            {
                int wordID = Convert.ToInt32(dgvWords.Rows[e.RowIndex].Cells["colID"].Value);
                DeleteWord(wordID);
                return;
            }

            // Click vào hàng → load lên form sửa
            LoadRowToInput(e.RowIndex);
        }

        private void LoadRowToInput(int rowIndex)
        {
            var row = dgvWords.Rows[rowIndex];
            selectedWordID = Convert.ToInt32(row.Cells["colID"].Value);

            // Chọn đúng chủ đề trong cboInputTopic
            string topicName = row.Cells["colTopic"].Value?.ToString() ?? "";
            foreach (ComboItem item in cboInputTopic.Items)
            {
                if (item.Name == topicName)
                {
                    cboInputTopic.SelectedItem = item;
                    break;
                }
            }

            txtEnglish.Text = row.Cells["colEnglish"].Value?.ToString() ?? "";
            txtPhonetic.Text = row.Cells["colPhonetic"].Value?.ToString() ?? "";
            txtVietnamese.Text = row.Cells["colVietnamese"].Value?.ToString() ?? "";
            txtHint.Text = row.Cells["colEmojiIcon"].Value?.ToString() ?? "";

            string diff = row.Cells["colDifficulty"].Value?.ToString() ?? "";
            int diffIdx = cboInputDiff.Items.IndexOf(diff);
            if (diffIdx >= 0) cboInputDiff.SelectedIndex = diffIdx;

            // Highlight hàng đang chọn
            dgvWords.ClearSelection();
            dgvWords.Rows[rowIndex].Selected = true;

            SetButtonState(true);
        }

        // ===================== THÊM / SỬA / XÓA =====================
        private void btnAdd_Click(object sender, EventArgs e)
        {
            if (!ValidateInput()) return;

            try
            {
                using var conn = new SqlConnection(connectionString);
                conn.Open();

                int topicID = ((ComboItem)cboInputTopic.SelectedItem).ID;
                string sql = @"INSERT INTO Words (TopicID, EnglishWord, Phonetic, VietnameseMeaning, DifficultyLevel, EmojiIcon)
               VALUES (@topicID, @en, @trans, @vi, @diff, @hint)";

                using var cmd = new SqlCommand(sql, conn);
                cmd.Parameters.AddWithValue("@topicID", topicID);
                cmd.Parameters.AddWithValue("@en", txtEnglish.Text.Trim());
                cmd.Parameters.AddWithValue("@trans", txtPhonetic.Text.Trim());
                cmd.Parameters.AddWithValue("@vi", txtVietnamese.Text.Trim());
                cmd.Parameters.AddWithValue("@diff", cboInputDiff.SelectedItem.ToString()!);
                cmd.Parameters.AddWithValue("@hint", txtHint.Text.Trim());

                cmd.ExecuteNonQuery();
                MessageBox.Show("✅ Thêm từ thành công!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
                ClearInput();
                ApplyFilter();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi thêm từ: " + ex.Message);
            }
        }

        private void btnUpdate_Click(object sender, EventArgs e)
        {
            if (selectedWordID < 0)
            {
                MessageBox.Show("Vui lòng chọn một từ để sửa!", "Chưa chọn từ", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            if (!ValidateInput()) return;

            try
            {
                using var conn = new SqlConnection(connectionString);
                conn.Open();

                int topicID = ((ComboItem)cboInputTopic.SelectedItem).ID;
                string sql = @"UPDATE Words SET
                                TopicID           = @topicID,
                                EnglishWord       = @en,
                                Phonetic          = @trans,
                                VietnameseMeaning = @vi,
                                DifficultyLevel   = @diff,
                                EmojiIcon         = @hint
                                WHERE WordID = @id";

                using var cmd = new SqlCommand(sql, conn);
                cmd.Parameters.AddWithValue("@topicID", topicID);
                cmd.Parameters.AddWithValue("@en", txtEnglish.Text.Trim());
                cmd.Parameters.AddWithValue("@trans", txtPhonetic.Text.Trim());
                cmd.Parameters.AddWithValue("@vi", txtVietnamese.Text.Trim());
                cmd.Parameters.AddWithValue("@diff", cboInputDiff.SelectedItem.ToString());
                cmd.Parameters.AddWithValue("@hint", txtHint.Text.Trim());
                cmd.Parameters.AddWithValue("@id", selectedWordID);

                cmd.ExecuteNonQuery();
                MessageBox.Show("✅ Cập nhật từ thành công!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
                ClearInput();
                ApplyFilter();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi sửa từ: " + ex.Message);
            }
        }

        private void btnDelete_Click(object sender, EventArgs e)
        {
            if (selectedWordID < 0)
            {
                MessageBox.Show("Vui lòng chọn một từ để xóa!", "Chưa chọn từ", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            string wordName = txtEnglish.Text;
            var result = MessageBox.Show(
                $"Bạn có chắc muốn xóa từ \"{wordName}\" không?",
                "Xác nhận xóa",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Warning
            );

            if (result == DialogResult.Yes)
                DeleteWord(selectedWordID);
        }

        private void DeleteWord(int wordID)
        {
            try
            {
                using var conn = new SqlConnection(connectionString);
                conn.Open();

                string sql = "DELETE FROM Words WHERE WordID = @id";
                using var cmd = new SqlCommand(sql, conn);
                cmd.Parameters.AddWithValue("@id", wordID);
                cmd.ExecuteNonQuery();

                ClearInput();
                ApplyFilter();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi xóa từ: " + ex.Message);
            }
        }

        // ===================== HELPERS =====================
        private bool ValidateInput()
        {
            if (cboInputTopic.SelectedItem == null)
            { MessageBox.Show("Vui lòng chọn chủ đề!", "Thiếu thông tin", MessageBoxButtons.OK, MessageBoxIcon.Warning); return false; }

            if (string.IsNullOrWhiteSpace(txtEnglish.Text))
            { MessageBox.Show("Vui lòng nhập từ tiếng Anh!", "Thiếu thông tin", MessageBoxButtons.OK, MessageBoxIcon.Warning); return false; }

            if (string.IsNullOrWhiteSpace(txtVietnamese.Text))
            { MessageBox.Show("Vui lòng nhập nghĩa tiếng Việt!", "Thiếu thông tin", MessageBoxButtons.OK, MessageBoxIcon.Warning); return false; }

            if (cboInputDiff.SelectedItem == null)
            { MessageBox.Show("Vui lòng chọn độ 3!", "Thiếu thông tin", MessageBoxButtons.OK, MessageBoxIcon.Warning); return false; }

            return true;
        }

        private void ClearInput()
        {
            selectedWordID = -1;
            if (cboInputTopic.Items.Count > 0) cboInputTopic.SelectedIndex = 0;
            txtEnglish.Text = "";
            txtPhonetic.Text = "";
            txtVietnamese.Text = "";
            txtHint.Text = "";
            cboInputDiff.SelectedIndex = 0;
            dgvWords.ClearSelection();
            SetButtonState(false);
        }

        private void SetButtonState(bool hasSelection)
        {
            btnUpdate.Enabled = hasSelection;
            btnDelete.Enabled = hasSelection;
        }

