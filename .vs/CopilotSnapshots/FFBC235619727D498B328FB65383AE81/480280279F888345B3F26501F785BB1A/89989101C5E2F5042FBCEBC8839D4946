        // Load chủ đề vào cboFilterTopic và cboInputTopic
        private void LoadTopicsToComboBox()
        {
            try
            {
                using var conn = new SqlConnection(connectionString);
                conn.Open();
                string sql = "SELECT TopicID, TopicName FROM Topics ORDER BY TopicName";
                using var cmd = new SqlCommand(sql, conn);
                using var reader = cmd.ExecuteReader();

                cboFilterTopic.Items.Clear();
                cboFilterTopic.Items.Add(new ComboItem(0, "Tất cả"));

                cboInputTopic.Items.Clear();

                while (reader.Read())
                {
                    var item = new ComboItem(
                        Convert.ToInt32(reader["TopicID"]),
                        reader["TopicName"].ToString()!
                    );
                    cboFilterTopic.Items.Add(item);
                    cboInputTopic.Items.Add(new ComboItem(
                        Convert.ToInt32(reader["TopicID"]),
                        reader["TopicName"].ToString()!
                    ));
                }

                cboFilterTopic.SelectedIndex = 0;
                if (cboInputTopic.Items.Count > 0)
                    cboInputTopic.SelectedIndex = 0;
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi load chủ đề: " + ex.Message);
            }
        }

        private void SetupDifficulty()
        {
            cboFilterDiff.Items.Clear();
            cboFilterDiff.Items.AddRange(new[] { "Tất cả", "1", "2", "3" });
            cboFilterDiff.SelectedIndex = 0;

            cboInputDiff.Items.Clear();
            cboInputDiff.Items.AddRange(new[] { "1", "2", "3" });
            cboInputDiff.SelectedIndex = 0;
        }

        // ===================== LOAD WORDS =====================
        private async void LoadWords(string filterTopic = "", string filterDiff = "", string search = "")
        {
            try
            {
                using var conn = new SqlConnection(connectionString);
                conn.Open();

                string sql = @"
            SELECT w.WordID, t.TopicName, w.EnglishWord, w.Phonetic,
       w.VietnameseMeaning, w.DifficultyLevel, w.EmojiIcon
            FROM Words w
            INNER JOIN Topics t ON w.TopicID = t.TopicID
            WHERE 1=1";

                if (!string.IsNullOrEmpty(filterTopic))
                    sql += " AND t.TopicName = @topic";

                if (!string.IsNullOrEmpty(filterDiff) && filterDiff != "Tất cả")
                    sql += " AND w.DifficultyLevel = @diff";

                if (!string.IsNullOrEmpty(search))
                    sql += " AND (w.EnglishWord LIKE @search OR w.VietnameseMeaning LIKE @search OR w.Phonetic LIKE @search)";

                sql += " ORDER BY t.TopicName, w.EnglishWord";

                using var cmd = new SqlCommand(sql, conn);

                if (!string.IsNullOrEmpty(filterTopic))
                    cmd.Parameters.AddWithValue("@topic", filterTopic);

                if (!string.IsNullOrEmpty(filterDiff) && filterDiff != "Tất cả")
                    cmd.Parameters.AddWithValue("@diff", filterDiff);

                if (!string.IsNullOrEmpty(search))
                    cmd.Parameters.AddWithValue("@search", "%" + search + "%");

                using var adapter = new SqlDataAdapter(cmd);
                DataTable dt = new DataTable();
                adapter.Fill(dt);

                // 🔥 CLEAR GRID
                dgvWords.Rows.Clear();

                // 🔥 ADD ROW GIỐNG LEADERBOARD
                foreach (DataRow row in dt.Rows)
                {
                    int idx = dgvWords.Rows.Add(
                        row["WordID"],
                        row["TopicName"],
                        row["EnglishWord"],
                        row["Phonetic"],
                        row["VietnameseMeaning"],
                        row["DifficultyLevel"],
                        row["EmojiIcon"],
                        "🗑"
                    );

                    // 🔥 TÔ MÀU ĐỘ 3
                    string diff = row["DifficultyLevel"].ToString()!;
                    ColorDifficultyCell(dgvWords.Rows[idx], diff);
                }

                UpdateCount(dt.Rows.Count);
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi load từ vựng: " + ex.Message);
            }
        }

        private void ColorDifficultyCell(DataGridViewRow row, string diff)
        {
            var cell = row.Cells["colDifficulty"];
            switch (diff)
            {
                case "1":
                    cell.Style.BackColor = Color.FromArgb(200, 230, 201);
                    cell.Style.ForeColor = Color.FromArgb(27, 94, 32);
                    break;
                case "2":
                    cell.Style.BackColor = Color.FromArgb(255, 249, 196);
                    cell.Style.ForeColor = Color.FromArgb(230, 81, 0);
                    break;
                case "3":
                    cell.Style.BackColor = Color.FromArgb(255, 205, 210);
                    cell.Style.ForeColor = Color.FromArgb(183, 28, 28);
                    break;
            }
            cell.Style.Font = new Font("Segoe UI", 9f, FontStyle.Bold);
            cell.Style.Alignment = DataGridViewContentAlignment.MiddleCenter;
        }

        private void UpdateCount(int count)
        {
            // Hiển thị tổng số từ lên title hoặc label nếu có
            this.label1.Text = $"WordQuest - Quản lý từ vựng  |  Tổng: {count} từ";
        }

