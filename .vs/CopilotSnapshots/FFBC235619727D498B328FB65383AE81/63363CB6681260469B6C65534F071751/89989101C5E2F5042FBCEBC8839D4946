        // ===================== LOAD TREEVIEW =====================
        private void LoadTopicTree()
        {
            treeTopics.Nodes.Clear();
            treeTopics.ShowLines = true;
            treeTopics.ShowPlusMinus = true;
            treeTopics.Font = new Font("Segoe UI", 10F);

            DataTable parents = DatabaseHelper.ExecuteQuery(
                "SELECT TopicID, TopicName, TopicIcon FROM Topics WHERE ParentID IS NULL ORDER BY SortOrder");

            foreach (DataRow parent in parents.Rows)
            {
                TreeNode parentNode = new TreeNode(
                    $"{parent["TopicIcon"]} {parent["TopicName"]}")
                {
                    Tag = parent["TopicID"],
                    NodeFont = new Font("Segoe UI", 10F, FontStyle.Bold),
                    ForeColor = Color.FromArgb(37, 99, 176)
                };

                // Load chủ đề con
                DataTable children = DatabaseHelper.ExecuteQuery(
                    "SELECT TopicID, TopicName, TopicIcon FROM Topics WHERE ParentID = @pid ORDER BY SortOrder",
                    new SqlParameter("@pid", parent["TopicID"]));

                foreach (DataRow child in children.Rows)
                {
                    TreeNode childNode = new TreeNode(
                        $"{child["TopicIcon"]} {child["TopicName"]}")
                    {
                        Tag = child["TopicID"]
                    };
                    parentNode.Nodes.Add(childNode);
                }

                treeTopics.Nodes.Add(parentNode);
            }

            // Node "Tất cả" ở đầu
            TreeNode allNode = new TreeNode("📋 Tất cả từ vựng")
            {
                Tag = -1,
                NodeFont = new Font("Segoe UI", 10F, FontStyle.Bold)
            };
            treeTopics.Nodes.Insert(0, allNode);

            treeTopics.ExpandAll();
        }

        // ===================== CLICK TREEVIEW → LỌC GRID =====================
        private void treeTopics_AfterSelect(object sender, TreeViewEventArgs e)
        {
            if (e.Node?.Tag == null) return;

            int topicID = Convert.ToInt32(e.Node.Tag);

            if (topicID == -1)
            {
                // Tất cả từ vựng
                ApplyFilter();
                return;
            }

            bool isParent = e.Node.Parent == null ||
                            Convert.ToInt32(e.Node.Tag) != -1 && e.Node.Nodes.Count > 0;

            if (isParent && e.Node.Nodes.Count > 0)
                LoadWordsByParentTopic(topicID);
            else
                LoadWordsByTopic(topicID);
        }

        private void LoadWordsByTopic(int topicID)
        {
            string sql = @"
        SELECT w.WordID, t.TopicName, w.EnglishWord, w.Phonetic,
               w.VietnameseMeaning, w.DifficultyLevel, w.EmojiIcon,
               w.ImagePath
        FROM Words w
        JOIN Topics t ON w.TopicID = t.TopicID
        WHERE w.TopicID = @tid
        ORDER BY w.EnglishWord";

            LoadWordsToGrid(DatabaseHelper.ExecuteQuery(sql,
                new SqlParameter("@tid", topicID)));
        }

        private void LoadWordsByParentTopic(int parentID)
        {
            string sql = @"
        SELECT w.WordID, t.TopicName, w.EnglishWord, w.Phonetic,
               w.VietnameseMeaning, w.DifficultyLevel, w.EmojiIcon,
               w.ImagePath
        FROM Words w
        JOIN Topics t ON w.TopicID = t.TopicID
        WHERE t.ParentID = @pid OR w.TopicID = @pid
        ORDER BY t.TopicName, w.EnglishWord";

            LoadWordsToGrid(DatabaseHelper.ExecuteQuery(sql,
                new SqlParameter("@pid", parentID)));
        }

        private void LoadWordsToGrid(DataTable dt)
        {
            dgvWords.Rows.Clear();

            foreach (DataRow row in dt.Rows)
            {
                int idx = dgvWords.Rows.Add(
                    row["WordID"],
                    row["TopicName"],
                    row["EnglishWord"],
                    row["Phonetic"],
                    row["VietnameseMeaning"],
                    row["DifficultyLevel"],
                    row["EmojiIcon"],
                    "🗑",
                    row["ImagePath"] == DBNull.Value ? "" : row["ImagePath"]
                );
                ColorDifficultyCell(dgvWords.Rows[idx],
                    row["DifficultyLevel"].ToString()!);
            }

            UpdateCount(dt.Rows.Count);
        }
    }
