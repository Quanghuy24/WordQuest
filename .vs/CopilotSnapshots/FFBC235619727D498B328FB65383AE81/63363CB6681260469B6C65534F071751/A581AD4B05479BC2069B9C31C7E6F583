using Microsoft.Data.SqlClient;
using System.Data;
using WordQuest.DTO;

namespace WordQuest.DAL
{
    public class GameRuleDAL
    {
        public GameRuleDTO GetGameRule()
        {
            const string sql = "SELECT TOP 1 RuleID, QuestionCount, TimeLimit, Lives, StreakBonus, Star1Threshold, Star2Threshold, Star3Threshold FROM GameRules ORDER BY RuleID ASC";
            var dt = DatabaseHelper.ExecuteQuery(sql);

            if (dt.Rows.Count == 0)
                return GetDefaultRule();

            var row = dt.Rows[0];
            return new GameRuleDTO
            {
                RuleID = Convert.ToInt32(row["RuleID"]),
                QuestionCount = Convert.ToInt32(row["QuestionCount"]),
                TimeLimit = Convert.ToInt32(row["TimeLimit"]),
                Lives = Convert.ToInt32(row["Lives"]),
                StreakBonus = Convert.ToInt32(row["StreakBonus"]),
                Star1Threshold = Convert.ToInt32(row["Star1Threshold"]),
                Star2Threshold = Convert.ToInt32(row["Star2Threshold"]),
                Star3Threshold = Convert.ToInt32(row["Star3Threshold"])
            };
        }

        public bool UpdateGameRule(GameRuleDTO rule)
        {
            const string sql = @"UPDATE GameRules 
                                 SET QuestionCount = @q, TimeLimit = @t, Lives = @l, 
                                     StreakBonus = @sb, Star1Threshold = @s1, Star2Threshold = @s2, Star3Threshold = @s3
                                 WHERE RuleID = (SELECT TOP 1 RuleID FROM GameRules ORDER BY RuleID ASC)";
            return DatabaseHelper.ExecuteNonQuery(sql,
                new SqlParameter("@q", rule.QuestionCount),
                new SqlParameter("@t", rule.TimeLimit),
                new SqlParameter("@l", rule.Lives),
                new SqlParameter("@sb", rule.StreakBonus),
                new SqlParameter("@s1", rule.Star1Threshold),
                new SqlParameter("@s2", rule.Star2Threshold),
                new SqlParameter("@s3", rule.Star3Threshold)) > 0;
        }

        public bool InsertGameRule(GameRuleDTO rule)
        {
            const string sql = @"INSERT INTO GameRules (QuestionCount, TimeLimit, Lives, StreakBonus, Star1Threshold, Star2Threshold, Star3Threshold)
                                 VALUES (@q, @t, @l, @sb, @s1, @s2, @s3)";
            return DatabaseHelper.ExecuteNonQuery(sql,
                new SqlParameter("@q", rule.QuestionCount),
                new SqlParameter("@t", rule.TimeLimit),
                new SqlParameter("@l", rule.Lives),
                new SqlParameter("@sb", rule.StreakBonus),
                new SqlParameter("@s1", rule.Star1Threshold),
                new SqlParameter("@s2", rule.Star2Threshold),
                new SqlParameter("@s3", rule.Star3Threshold)) > 0;
        }

        public bool HasAnyRule()
        {
            const string sql = "SELECT COUNT(1) FROM GameRules";
            return Convert.ToInt32(DatabaseHelper.ExecuteScalar(sql)) > 0;
        }

        private static GameRuleDTO GetDefaultRule()
        {
            return new GameRuleDTO
            {
                QuestionCount = 15,
                TimeLimit = 60,
                Lives = 3,
                StreakBonus = 5,
                Star1Threshold = 5,
                Star2Threshold = 10,
                Star3Threshold = 15
            };
        }
    }
}