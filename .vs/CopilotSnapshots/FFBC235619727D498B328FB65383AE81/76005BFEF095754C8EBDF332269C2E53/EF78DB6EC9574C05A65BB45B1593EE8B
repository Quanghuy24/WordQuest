        /// <summary>
        /// Xử lý gợi ý
        /// </summary>
        private void HandleHint()
        {
            if (_isAnswered || _isGameEnding || _isWaitingForNext) return;

            string letter = _answerBUS.UseHint();
            if (letter == null) return;

            int currentIndex = _answerBUS.GetFilledLetters().Count - 1;
            if (currentIndex < 0 || currentIndex >= _answerSlots.Count) return;

            // Cập nhật UI
            _answerSlots[currentIndex].Text = letter;
            _answerSlots[currentIndex].BackColor = HINT_COLOR;

            // Ẩn nút chữ cái tương ứng
            var button = _letterButtons.FirstOrDefault(b => b.Text == letter && b.Visible);
            if (button != null)
            {
                button.Visible = false;
            }

            // Trừ điểm khi dùng gợi ý
            _score = Math.Max(0, _score - HINT_PENALTY_SCORE);

            // Kiểm tra nếu đã điền đầy đủ
            if (_answerBUS.IsFull())
            {
                CheckAnswer();
            }
        }

        #endregion

        #region ==================== UI Updates ====================

        /// <summary>
        /// Cập nhật hiển thị mạng sống
        /// </summary>
        private void UpdateLivesDisplay()
        {
            int maxLives = Math.Max(1, _currentRule?.Lives ?? 3);
            lblLives.Text = string.Concat(Enumerable.Range(0, maxLives)
                .Select(i => i < _lives ? "❤️" : "🖤"));
        }

        /// <summary>
        /// Cập nhật hiển thị streak
        /// </summary>
        private void UpdateStreakDisplay()
        {
            lblStreak.Text = $"🔥 {_streak}";
        }

        /// <summary>
        /// Phát âm thanh
        /// </summary>
        private void PlaySound(bool isCorrect)
        {
            try
            {
                if (isCorrect)
                {
                    System.Media.SystemSounds.Asterisk.Play();
                }
                else
                {
                    System.Media.SystemSounds.Hand.Play();
                }
            }
            catch
            {
                // Bỏ qua lỗi âm thanh
            }
        }

        #endregion

        #region ==================== Game End ====================

        /// <summary>
        /// Kết thúc game
        /// </summary>
        private async void EndGame()
        {
            if (_isGameEnding) return;
            _isGameEnding = true;

            StopTimer();

            int stars = CalculateStars();

            try
            {
                await SaveGameResultAsync(stars);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Lỗi lưu tiến độ: {ex.Message}", "Lỗi",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }

            // Hiển thị form kết thúc
            ShowResultForm(stars);
        }

        /// <summary>
        /// Tính số sao đạt được
        /// </summary>
        private int CalculateStars()
        {
            if (_currentRule == null) return 0;

            if (_correctCount >= _currentRule.Star3Threshold) return 3;
            if (_correctCount >= _currentRule.Star2Threshold) return 2;
            if (_correctCount >= _currentRule.Star1Threshold) return 1;
            return 0;
        }

        /// <summary>
        /// Lưu kết quả game bất đồng bộ
        /// </summary>
        private async Task SaveGameResultAsync(int stars)
        {
            await Task.Run(() =>
            {
                _progressBUS.SaveProgress(_playerID, _topicID, _levelNum, _score, stars);
                _scoreBUS.SaveScoreHistory(_playerID, _topicID, _levelNum, _score, stars, _totalTimeSpentMs / 1000);
                _playerBUS.UpdatePlayerStats(_playerID, _score, stars);
            });
        }

        /// <summary>
        /// Hiển thị form kết quả
        /// </summary>
        private void ShowResultForm(int stars)
        {
            CleanupResources();

            var resultForm = new frmWin(
                _playerID, "",
                _topicID, _topicName, _topicEmoji,
                _levelNum, _score, stars,
                _correctCount, _totalTimeSpentMs / 1000,
                _wordsTable.Rows.Count, _gameMode)
            {
                Owner = this.Owner
            };
            resultForm.Show();
            Close();
        }

        /// <summary>
        /// Xử lý thoát game
        /// </summary>
        private void HandleExitGame()
        {
            if (_isGameEnding) return;

            StopTimer();

            var result = MessageBox.Show("Bạn có chắc muốn thoát?\nTiến độ sẽ không được lưu!",
                "Thoát game", MessageBoxButtons.YesNo, MessageBoxIcon.Question);

            if (result == DialogResult.Yes)
            {
                _isGameEnding = true;
                CleanupResources();

                Owner?.Show();
                Close();
            }
            else
            {
                StartTimer();
            }
        }

        #endregion

        #region ==================== Resource Management ====================

        /// <summary>
        /// Dọn dẹp tài nguyên
        /// </summary>
        private void CleanupResources()
        {
            // Giải phóng SpeechSynthesizer
            if (_speechSynthesizer != null)
            {
                try
                {
                    _speechSynthesizer.Dispose();
                }
                catch
                {
                    // Bỏ qua lỗi dispose
                }
                _speechSynthesizer = null;
            }

            // Giải phóng ảnh trong PictureBox
            if (picWord.Image != null)
            {
                try
                {
                    picWord.Image.Dispose();
                }
                catch { }
                picWord.Image = null;
            }
        }

        #endregion
    }
