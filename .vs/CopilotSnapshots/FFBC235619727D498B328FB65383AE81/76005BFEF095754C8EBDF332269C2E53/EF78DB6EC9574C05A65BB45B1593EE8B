        #region ==================== Initialization ====================

        /// <summary>
        /// Khởi tạo game bất đồng bộ
        /// </summary>
        private async Task InitializeGameAsync()
        {
            try
            {
                // Hiển thị loading cursor
                Cursor = Cursors.WaitCursor;

                // Tải luật chơi
                _currentRule = await Task.Run(() => _gameBUS.GetGameRule());
                InitializeGameState();

                // Thiết lập giao diện
                SetupUI();

                // Tải danh sách từ vựng
                _wordsTable = await Task.Run(() => _gameBUS.GetWordsForLevel(_levelID));

                if (!ValidateGameData())
                {
                    Close();
                    return;
                }

                // Khởi tạo Speech Synthesizer
                InitializeSpeechSynthesizer();

                // Hiển thị câu hỏi đầu tiên
                ShowCurrentWord();
            }
            catch (Exception ex)
            {
                HandleInitializationError(ex);
            }
            finally
            {
                Cursor = Cursors.Default;
            }
        }

        /// <summary>
        /// Khởi tạo giá trị mặc định cho game
        /// </summary>
        private void InitializeGameState()
        {
            _lives = _currentRule?.Lives ?? 3;
            _streak = 0;
            _score = 0;
            _correctCount = 0;
            _totalTimeSpentMs = 0;
            _currentWordIndex = 0;
            _isGameEnding = false;
            _isAnswered = false;
            _isWaitingForNext = false;
        }

        /// <summary>
        /// Thiết lập giao diện người dùng
        /// </summary>
        private void SetupUI()
        {
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = Color.FromArgb(101, 67, 33);

            // Header Panel
            pnlHeader.BackColor = Color.FromArgb(75, 45, 15);

            // Picture Box
            picWord.BackColor = Color.FromArgb(120, 80, 40);
            picWord.SizeMode = PictureBoxSizeMode.Zoom;

            // Labels
            lblStreak.Text = "🔥 0";
            lblQuestion.ForeColor = Color.White;
            lblEnglish.Visible = false;

            // Hint Button
            btnHint.BackColor = Color.FromArgb(247, 201, 72);
            btnHint.FlatStyle = FlatStyle.Flat;

            // Progress Bar - chỉ hiển thị 0 nếu chưa có giá trị
            pbTime.Minimum = 0;
            pbTime.Maximum = 100; // Sẽ được cập nhật lại sau
            pbTime.Value = 0;

            // Timer
            gameTimer.Interval = TIMER_INTERVAL_MS;

            UpdateLivesDisplay();
        }

        /// <summary>
        /// Khởi tạo SpeechSynthesizer để đọc từ tiếng Anh
        /// </summary>
        private void InitializeSpeechSynthesizer()
        {
            try
            {
                _speechSynthesizer = new SpeechSynthesizer();
                _speechSynthesizer.SelectVoiceByHints(VoiceGender.Female, VoiceAge.Child);
            }
            catch
            {
                _speechSynthesizer = null; // Không có voice thì bỏ qua
            }
        }

        /// <summary>
        /// Kiểm tra dữ liệu game có hợp lệ không
        /// </summary>
        private bool ValidateGameData()
        {
            if (_wordsTable == null || _wordsTable.Rows.Count == 0)
            {
                MessageBox.Show("Không có dữ liệu câu hỏi cho màn này!", "Thông báo",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }
            return true;
        }

        /// <summary>
        /// Xử lý lỗi khởi tạo game
        /// </summary>
        private void HandleInitializationError(Exception ex)
        {
            MessageBox.Show($"Lỗi khởi tạo game: {ex.Message}", "Lỗi",
                MessageBoxButtons.OK, MessageBoxIcon.Error);
            Close();
        }

