using System;
using System.Data;
using System.Drawing;
using System.IO;
using System.Net.Http;
using System.Text.Json;
using System.Threading.Tasks;
using System.Windows.Forms;
using WordQuest.BUS;

namespace WordQuest.GUI
{
    public partial class frmImage : Form
    {
        public string SelectedImagePath { get; private set; } = "";

        private readonly ImageBUS _imageBUS = new();
        private readonly string _imagesFolder = Path.Combine(Application.StartupPath, "Images");
        private static readonly HttpClient _httpClient = new();
        private const string PIXABAY_API_KEY = "55569915-c60f8d14e1ac943e537881b67";

        public frmImage()
        {
            InitializeComponent();
        }

        private async void frmImage_Load(object sender, EventArgs e)
        {
            Directory.CreateDirectory(_imagesFolder);
            SetupControls();
            ShowTab(1);
            await LoadLibrary();
        }

        private void SetupControls()
        {
            cboFilterImage.Items.Clear();
            cboFilterImage.Items.AddRange(new[] { "Tất cả", "Đang dùng", "Chưa dùng" });
            cboFilterImage.SelectedIndex = 0;

            imgListLarge.ImageSize = new Size(80, 80);
            imgListPixabay.ImageSize = new Size(80, 80);

            lvImages.LargeImageList = imgListLarge;
            lvPixResult.LargeImageList = imgListPixabay;

            picPreview.Image = null;
        }

        private void ShowTab(int tab)
        {
            pnlLibrary.Visible = (tab == 1);
            pnlPixabay.Visible = (tab == 2);
            pnlPixabay.Location = pnlLibrary.Location;
            pnlPixabay.Size = pnlLibrary.Size;

            btnTab1.BackColor = tab == 1 ? Color.FromArgb(37, 99, 176) : Color.FromArgb(220, 220, 230);
            btnTab2.BackColor = tab == 2 ? Color.FromArgb(37, 99, 176) : Color.FromArgb(220, 220, 230);
            btnTab1.ForeColor = tab == 1 ? Color.White : Color.FromArgb(80, 80, 80);
            btnTab2.ForeColor = tab == 2 ? Color.White : Color.FromArgb(80, 80, 80);
        }

        private async Task LoadLibrary(string keyword = "", string filter = "Tất cả")
        {
            lvImages.Items.Clear();
            imgListLarge.Images.Clear();

            var dt = await Task.Run(() => _imageBUS.GetAllImages(keyword));

            foreach (DataRow row in dt.Rows)
            {
                bool isUsed = Convert.ToInt32(row["IsUsed"]) == 1;
                string imagePath = row["ImagePath"].ToString() ?? "";
                string imageName = row["ImageName"].ToString() ?? "";
                int imageID = Convert.ToInt32(row["ImageID"]);

                if (filter == "Đang dùng" && !isUsed) continue;
                if (filter == "Chưa dùng" && isUsed) continue;

                string fullPath = Path.Combine(Application.StartupPath, imagePath);
                Image img = LoadImageSafe(fullPath);

                string key = imageID.ToString();
                imgListLarge.Images.Add(key, img);

                var item = new ListViewItem(imageName) { ImageKey = key, Tag = row };
                item.ForeColor = isUsed ? Color.FromArgb(29, 78, 216) : Color.FromArgb(120, 120, 120);
                lvImages.Items.Add(item);
            }

            lblStatusBar.Text = $"Tổng: {lvImages.Items.Count} ảnh";
        }

        private Image LoadImageSafe(string fullPath)
        {
            if (!File.Exists(fullPath)) return SystemIcons.Question.ToBitmap();
            try
            {
                byte[] bytes = File.ReadAllBytes(fullPath);
                using var ms = new MemoryStream(bytes);
                using var tmp = Image.FromStream(ms);
                return new Bitmap(tmp);
            }
            catch { return SystemIcons.Question.ToBitmap(); }
        }

        private async void btnAddImage_Click(object sender, EventArgs e)
        {
            using var dlg = new OpenFileDialog();
            dlg.Filter = "Image Files|*.png;*.jpg;*.jpeg;*.bmp";
            if (dlg.ShowDialog() != DialogResult.OK) return;

            string relativePath = await Task.Run(() => _imageBUS.AddImageFromFile(dlg.FileName));
            SelectedImagePath = relativePath;
            await LoadLibrary();
            MessageBox.Show("Thêm ảnh thành công!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Information);
        }

        private async void btnDeleteImage_Click(object sender, EventArgs e)
        {
            if (lvImages.SelectedItems.Count == 0)
            {
                MessageBox.Show("Vui lòng chọn ảnh cần xóa!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var row = (DataRow)lvImages.SelectedItems[0].Tag;
            bool isUsed = Convert.ToInt32(row["IsUsed"]) == 1;
            int imageID = Convert.ToInt32(row["ImageID"]);

            if (isUsed)
            {
                MessageBox.Show("Ảnh này đang được dùng! Không thể xóa.", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var confirm = MessageBox.Show("Xóa ảnh này?", "Xác nhận", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            if (confirm != DialogResult.Yes) return;

            await Task.Run(() => _imageBUS.DeleteImage(imageID));
            picPreview.Image = null;
            await LoadLibrary();
        }

        private async void btnSearchImage_Click(object sender, EventArgs e)
        {
            await LoadLibrary(txtSearchImage.Text.Trim(), cboFilterImage.SelectedItem?.ToString() ?? "Tất cả");
        }

        private async void cboFilterImage_SelectedIndexChanged(object sender, EventArgs e)
        {
            await LoadLibrary(txtSearchImage.Text.Trim(), cboFilterImage.SelectedItem?.ToString() ?? "Tất cả");
        }

        private void lvImages_SelectedIndexChanged(object sender, EventArgs e)
        {
            if (lvImages.SelectedItems.Count == 0) return;
            var row = (DataRow)lvImages.SelectedItems[0].Tag;
            string imagePath = row["ImagePath"].ToString() ?? "";
            bool isUsed = Convert.ToInt32(row["IsUsed"]) == 1;

            ShowPreview(imagePath, row["ImageName"].ToString() + Path.GetExtension(imagePath), isUsed);
        }

        private async void btnPixSearch_Click(object sender, EventArgs e)
        {
            string keyword = txtPixSearch.Text.Trim();
            if (string.IsNullOrEmpty(keyword))
            {
                MessageBox.Show("Vui lòng nhập từ tiếng Anh!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            btnPixSearch.Enabled = false;
            btnPixSearch.Text = "Đang tìm...";
            lvPixResult.Items.Clear();
            imgListPixabay.Images.Clear();

            try
            {
                string url = $"https://pixabay.com/api/?key={PIXABAY_API_KEY}&q={Uri.EscapeDataString(keyword)}&image_type=illustration&per_page=15&safesearch=true";
                string json = await _httpClient.GetStringAsync(url);
                using var doc = JsonDocument.Parse(json);
                var hits = doc.RootElement.GetProperty("hits");

                int index = 0;
                foreach (var hit in hits.EnumerateArray())
                {
                    string previewUrl = hit.GetProperty("previewURL").GetString() ?? "";
                    string tags = hit.GetProperty("tags").GetString() ?? "";
                    int pixID = hit.GetProperty("id").GetInt32();

                    byte[] imgBytes = await _httpClient.GetByteArrayAsync(previewUrl);
                    using var ms = new MemoryStream(imgBytes);
                    using var tmp = Image.FromStream(ms);
                    var img = new Bitmap(tmp);

                    string key = $"pix_{index}";
                    imgListPixabay.Images.Add(key, img);

                    var item = new ListViewItem(tags.Length > 15 ? tags[..15] + "..." : tags)
                    {
                        ImageKey = key,
                        Tag = new PixabayResult { PixID = pixID, Tags = tags, PreviewURL = previewUrl, FullURL = hit.GetProperty("largeImageURL").GetString() ?? previewUrl }
                    };
                    lvPixResult.Items.Add(item);
                    index++;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Lỗi tìm ảnh: {ex.Message}", "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                btnPixSearch.Enabled = true;
                btnPixSearch.Text = "🔍 Tìm ảnh trên Pixabay";
            }
        }

        private void lvPixResult_SelectedIndexChanged(object sender, EventArgs e)
        {
            if (lvPixResult.SelectedItems.Count == 0) return;
            var result = (PixabayResult)lvPixResult.SelectedItems[0].Tag;
            string key = lvPixResult.SelectedItems[0].ImageKey;
            if (imgListPixabay.Images.ContainsKey(key))
                SetPreviewImage(new Bitmap(imgListPixabay.Images[key]));

            lblFileName.Text = $"Tên file: {result.Tags}";
            lblFilePath.Text = $"Nguồn: Pixabay #{result.PixID}";
            lblFileStatus.Text = "Trạng thái: Chưa tải về";
        }

        private async void btnDownload_Click(object sender, EventArgs e)
        {
            if (lvPixResult.SelectedItems.Count == 0)
            {
                MessageBox.Show("Vui lòng chọn ảnh cần tải!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var result = (PixabayResult)lvPixResult.SelectedItems[0].Tag;
            string fileName = $"pixabay_{result.PixID}.jpg";
            string destPath = Path.Combine(_imagesFolder, fileName);
            string relPath = Path.Combine("Images", fileName);

            btnDownload.Enabled = false;
            btnDownload.Text = "Đang tải...";

            try
            {
                byte[] imgBytes = await _httpClient.GetByteArrayAsync(result.FullURL);
                await File.WriteAllBytesAsync(destPath, imgBytes);

                string imageName = result.Tags.Split(',')[0].Trim();
                await Task.Run(() => _imageBUS.AddImageFromUrl(imgBytes, fileName));

                SelectedImagePath = relPath;

                MessageBox.Show($"Đã tải ảnh '{imageName}' vào thư viện!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);

                ShowTab(1);
                await LoadLibrary();

                foreach (ListViewItem it in lvImages.Items)
                {
                    if (it.Tag is DataRow r && (r["ImagePath"]?.ToString() ?? "") == relPath)
                    {
                        it.Selected = true;
                        lvImages.EnsureVisible(it.Index);
                        break;
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Lỗi tải ảnh: {ex.Message}", "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                btnDownload.Enabled = true;
                btnDownload.Text = "⬇ Tải về & lưu vào thư viện";
            }
        }

        private void ShowPreview(string imagePath, string fileName, bool isUsed)
        {
            string fullPath = Path.Combine(Application.StartupPath, imagePath);
            if (File.Exists(fullPath))
                picPreview.Image = LoadImageSafe(fullPath);
            else
                picPreview.Image = null;

            lblFileName.Text = $"Tên file: {fileName}";
            lblFilePath.Text = $"Đường dẫn: {imagePath}";
            lblFileStatus.Text = isUsed ? "Trạng thái: Đang dùng" : "Trạng thái: Chưa dùng";
        }

        private void btnSelectImage_Click(object sender, EventArgs e)
        {
            if (pnlLibrary.Visible)
            {
                if (lvImages.SelectedItems.Count == 0)
                {
                    MessageBox.Show("Vui lòng chọn ảnh!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
                var row = (DataRow)lvImages.SelectedItems[0].Tag;
                SelectedImagePath = row["ImagePath"].ToString() ?? "";
            }
            else if (string.IsNullOrEmpty(SelectedImagePath))
            {
                MessageBox.Show("Vui lòng tải ảnh về trước!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            DialogResult = DialogResult.OK;
            
        }

        private void btnClose_Click(object sender, EventArgs e)
        {
            DialogResult = DialogResult.Cancel;
            
        }

        private void SetPreviewImage(Image newImage)
        {
            var old = picPreview.Image;
            picPreview.Image = newImage;
            old?.Dispose();
        }

        private void btnTab1_Click(object sender, EventArgs e) => ShowTab(1);
        private void btnTab2_Click(object sender, EventArgs e) => ShowTab(2);

        private class PixabayResult
        {
            public int PixID { get; set; }
            public string Tags { get; set; } = "";
            public string PreviewURL { get; set; } = "";
            public string FullURL { get; set; } = "";
        }
    }
}