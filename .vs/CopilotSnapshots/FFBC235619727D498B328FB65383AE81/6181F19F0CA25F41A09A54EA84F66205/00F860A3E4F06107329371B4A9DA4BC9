using System;
using System.Data;
using Microsoft.Data.SqlClient;

namespace WordQuest
{
    internal class GameRepository
    {
        public GameRule GetGameRule()
        {
            const string sql = "SELECT TOP 1 * FROM GameRules ORDER BY RuleID ASC";

            try
            {
                DataTable dt = DatabaseHelper.ExecuteQuery(sql);

                if (dt.Rows.Count == 0)
                    return GetDefaultRule();

                DataRow row = dt.Rows[0];

                return new GameRule
                {
                    QuestionCount = Convert.ToInt32(row["QuestionCount"]),
                    TimeLimit = Convert.ToInt32(row["TimeLimit"]),
                    Lives = Convert.ToInt32(row["Lives"]),
                    StreakBonus = Convert.ToInt32(row["StreakBonus"]),
                    Star1Threshold = Convert.ToInt32(row["Star1Threshold"]),
                    Star2Threshold = Convert.ToInt32(row["Star2Threshold"]),
                    Star3Threshold = Convert.ToInt32(row["Star3Threshold"])
                };
            }
            catch
            {
                return GetDefaultRule();
            }
        }

        // GameRepository.cs

        public DataTable GetWordsByLevelID(int levelID)
        {
            // Lấy thông tin màn chơi (Mode, DifficultyLevel, QuestionCount)
            string levelQuery = @"
        SELECT Mode, DifficultyLevel, QuestionCount, TopicID
        FROM Levels
        WHERE LevelID = @LevelID";

            var levelRow = DatabaseHelper.ExecuteQuery(levelQuery,
                new SqlParameter("@LevelID", levelID)).Rows[0];

            string mode = levelRow["Mode"].ToString();        // 'Random' hoặc 'Fixed'
            string diff = levelRow["DifficultyLevel"].ToString();
            int count = Convert.ToInt32(levelRow["QuestionCount"]);
            int topicID = Convert.ToInt32(levelRow["TopicID"]);

            if (mode == "Fixed")
            {
                // Lấy đúng từ trong bảng LevelWords
                string fixedQuery = @"
            SELECT w.WordID, w.EnglishWord, w.VietnameseMeaning,
                   w.Phonetic, w.EmojiIcon, w.ImagePath, w.DifficultyLevel
            FROM LevelWords lw
            JOIN Words w ON lw.WordID = w.WordID
            WHERE lw.LevelID = @LevelID
            ORDER BY NEWID()"; //hoặc ORDER BY lw.LevelWordID nếu muốn cố định thứ tự
        
        return DatabaseHelper.ExecuteQuery(fixedQuery,
            new SqlParameter("@LevelID", levelID));
            }
            else
            {
                // Random theo DifficultyLevel của màn, giới hạn QuestionCount
                string randomQuery = @"
            SELECT TOP (@Count)
                   w.WordID, w.EnglishWord, w.VietnameseMeaning,
                   w.Phonetic, w.EmojiIcon, w.ImagePath, w.DifficultyLevel
            FROM Words w
            WHERE w.TopicID = @TopicID
              AND w.DifficultyLevel = @Diff
            ORDER BY NEWID()";

                return DatabaseHelper.ExecuteQuery(randomQuery,
                    new SqlParameter("@Count", count),
                    new SqlParameter("@TopicID", topicID),
                    new SqlParameter("@Diff", diff));
            }
        }

        public DataTable GetWordsByTopicAndDifficulty(int topicID, int difficultyLevel, int count)
        {
            const string sql = @"
                SELECT TOP (@count)
                       WordID, EnglishWord, VietnameseMeaning, Phonetic, EmojiIcon
                FROM Words
                WHERE TopicID = @topicID AND DifficultyLevel = @difficulty
                ORDER BY NEWID()";

            SqlParameter[] parameters =
            {
                new("@count", count),
                new("@topicID", topicID),
                new("@difficulty", difficultyLevel)
            };

            return DatabaseHelper.ExecuteQuery(sql, parameters);
        }

        public void SaveScoreHistory(
            int playerID,
            int topicID,
            int levelNum,
            int score,
            int stars,
            int timeTaken)
        {
            const string sql = @"
                INSERT INTO ScoreHistory
                (PlayerID, TopicID, LevelNum, Score, Stars, TimeTaken, PlayedAt)
                VALUES
                (@pid, @tid, @lvl, @score, @stars, @timeTaken, GETDATE())";

            SqlParameter[] parameters =
            {
                new("@pid", playerID),
                new("@tid", topicID),
                new("@lvl", levelNum),
                new("@score", score),
                new("@stars", stars),
                new("@timeTaken", timeTaken)
            };

            DatabaseHelper.ExecuteNonQuery(sql, parameters);
        }

        public void SaveProgress(
            int playerID,
            int topicID,
            int levelNum,
            int score,
            int stars)
        {
            DatabaseHelper.ExecuteInTransaction(tran =>
            {
                const string upsertProgress = @"
                    IF EXISTS (
                        SELECT 1
                        FROM PlayerProgress
                        WHERE PlayerID = @pid AND TopicID = @tid AND LevelNum = @lvl
                    )
                    BEGIN
                        UPDATE PlayerProgress
                        SET Stars = CASE WHEN @stars > Stars THEN @stars ELSE Stars END,
                            BestScore = CASE WHEN @score > BestScore THEN @score ELSE BestScore END,
                            IsCompleted = 1,
                            CompletedAt = GETDATE()
                        WHERE PlayerID = @pid AND TopicID = @tid AND LevelNum = @lvl
                    END
                    ELSE
                    BEGIN
                        INSERT INTO PlayerProgress
                        (PlayerID, TopicID, LevelNum, Stars, BestScore, IsCompleted, CompletedAt)
                        VALUES
                        (@pid, @tid, @lvl, @stars, @score, 1, GETDATE())
                    END";

                SqlParameter[] progressParams =
                {
                    new("@pid", playerID),
                    new("@tid", topicID),
                    new("@lvl", levelNum),
                    new("@stars", stars),
                    new("@score", score)
                };

                DatabaseHelper.ExecuteNonQuery(upsertProgress, progressParams, tran);

                const string updatePlayer = @"
                    UPDATE Players
                    SET TotalStars = (
                            SELECT ISNULL(SUM(Stars), 0)
                            FROM PlayerProgress
                            WHERE PlayerID = @pid
                        ),
                        TotalScore = TotalScore + @score,
                        LastPlayed = GETDATE()
                    WHERE PlayerID = @pid";

                SqlParameter[] playerParams =
                {
                    new("@pid", playerID),
                    new("@score", score)
                };

                DatabaseHelper.ExecuteNonQuery(updatePlayer, playerParams, tran);
            });
        }


        private GameRule GetDefaultRule()
        {
            return new GameRule
            {
                QuestionCount = 15,
                TimeLimit = 60,
                Lives = 3,
                StreakBonus = 5,
                Star1Threshold = 5,
                Star2Threshold = 10,
                Star3Threshold = 15
            };
        }
    }
